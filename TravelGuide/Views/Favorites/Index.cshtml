@model IEnumerable<TravelGuide.Models.Entities.FavoriteTour>
@using TravelGuide.Models.Entities

@{
    ViewData["Title"] = "Избранные туры";
    var favoritesList = Model.ToList();
}

<!-- Hero Section -->
<section class="hero-section text-center">
    <div class="container position-relative">
        <h1>Избранные туры</h1>
        <p class="lead">Ваши любимые направления в одном месте</p>
    </div>
</section>

<div class="container">
    <!-- Сообщения -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-4">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    @if (!favoritesList.Any())
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <svg width="64" height="64" fill="none" stroke="var(--text-light)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            </div>
            <h3 class="fw-bold">У вас пока нет избранных туров</h3>
            <p class="text-muted mb-4">Добавляйте туры в избранное, чтобы вернуться к ним позже</p>
            <a asp-controller="Tours" asp-action="Index" class="btn btn-primary btn-lg px-5">Искать туры</a>
        </div>
    }
    else
    {
        <!-- Поиск карточка -->
        <div class="search-card mt-4 mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0 fw-bold">Найдено: <span class="text-primary">@favoritesList.Count</span></h4>
                </div>
                <a asp-controller="Tours" asp-action="Index" class="btn btn-primary">Добавить ещё</a>
            </div>
        </div>

        <!-- Сетка туров -->
        <div class="row g-4 mb-5">
            @foreach (var favorite in favoritesList)
            {
                var tour = favorite.Tour!;
                var avgRating = tour.Reviews != null && tour.Reviews.Any()
                    ? tour.Reviews.Average(r => r.Rating)
                    : 0;
                var reviewCount = tour.Reviews?.Count ?? 0;

                <div class="col-md-6 col-lg-3">
                    <div class="card h-100 tour-card border-0">
                        @if (!string.IsNullOrEmpty(tour.PhotoUrl))
                        {
                            <img src="@tour.PhotoUrl" class="card-img-top" alt="@tour.Name" style="height: 200px; object-fit: cover; border-radius: 12px 12px 0 0;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px; border-radius: 12px 12px 0 0;">
                                <span class="text-muted">Нет фото</span>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title text-truncate">@tour.Name</h5>
                            <p class="text-muted small mb-2">
                                @if (tour.Country != null)
                                {
                                    <span>@tour.Country.Name</span>
                                }
                            </p>
                            <div class="d-flex align-items-center mb-2">
                                @if (reviewCount > 0)
                                {
                                    <span class="star-rating">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= Math.Round(avgRating))
                                            {
                                                <span>★</span>
                                            }
                                            else
                                            {
                                                <span class="empty">★</span>
                                            }
                                        }
                                    </span>
                                    <span class="text-muted small ms-2">(@reviewCount)</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Нет отзывов</span>
                                }
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="price-tag">@tour.Price.ToString("N0") ₽</span>
                                <span class="duration-badge">@tour.Duration дн.</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pt-0">
                            <div class="d-flex gap-2">
                                <a asp-controller="Tours" asp-action="Details" asp-route-id="@tour.Id" class="btn btn-outline-primary flex-grow-1">
                                    Подробнее
                                </a>
                                <form asp-action="RemoveFromList" asp-route-id="@tour.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger" title="Удалить из избранного">
                                        <svg width="16" height="16" fill="currentColor" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                                    </button>
                                </form>
                            </div>
                            <small class="text-muted d-block mt-2 text-center">
                                Добавлен: @favorite.AddedDate.ToString("dd.MM.yyyy")
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
