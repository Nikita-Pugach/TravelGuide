@{
    ViewData["Title"] = "О проекте";
}

<!-- Hero Section -->
<section class="hero-section text-center">
    <div class="container position-relative">
        <h1>О проекте TravelGuide</h1>
        <p class="lead">Справочник туриста — веб-приложение для поиска и бронирования туров</p>
    </div>
</section>

<div class="container py-5">

    <!-- Описание + Инфо -->
    <div class="card tour-card mb-5">
        <div class="card-body p-4">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <h2 class="fw-bold mb-3">Что это за проект?</h2>
                    <p style="line-height:1.9;color:var(--text-dark)">
                        <strong>TravelGuide</strong> — веб-приложение для поиска, сравнения и бронирования туров, отелей и достопримечательностей. 
                        Разработано в рамках курсовой работы по дисциплине "Разработка и сопровождение программного обеспечения" (РСПО).
                    </p>
                    <p style="line-height:1.9;color:var(--text-dark)">
                        Пользователи могут просматривать каталоги с фильтрами, бронировать туры, добавлять в избранное, 
                        писать отзывы и общаться с поддержкой в реальном времени.
                    </p>
                </div>
                <div class="col-lg-4">
                    <div class="text-center p-3 rounded-3" style="background:var(--bg-light)">
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:80px;height:80px;background:linear-gradient(135deg,var(--primary),#5ba4e5);color:white;font-size:1.8rem;font-weight:700">
                            НП
                        </div>
                        <h6 class="fw-bold mb-1">Пугач Никита</h6>
                        <p class="text-muted small mb-1">Группа Т-393</p>
                        <p class="text-muted small mb-0">Колледж бизнеса и права</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Технологии -->
    <h2 class="fw-bold text-center mb-4">Технологии</h2>
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card tour-card h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3" style="color:var(--primary)">Backend</h5>
                    <ul class="text-muted mb-0" style="line-height:2.2">
                        <li>ASP.NET Core MVC 9.0</li>
                        <li>Entity Framework Core 9.0</li>
                        <li>SQLite — база данных</li>
                        <li>SignalR — чат в реальном времени</li>
                        <li>BCrypt.Net — хеширование паролей</li>
                        <li>ClosedXML — Excel-отчёты</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card tour-card h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3" style="color:var(--primary)">Frontend</h5>
                    <ul class="text-muted mb-0" style="line-height:2.2">
                        <li>Razor Views</li>
                        <li>Bootstrap 5</li>
                        <li>Leaflet.js — карты</li>
                        <li>CSS custom properties</li>
                        <li>Адаптивный дизайн</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Возможности -->
    <h2 class="fw-bold text-center mb-4">Возможности приложения</h2>
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card tour-card h-100 text-center p-4">
                <div class="mb-3">
                    <svg width="40" height="40" fill="none" stroke="var(--primary)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </div>
                <h5 class="fw-bold">Поиск туров</h5>
                <p class="text-muted small mb-0">Фильтрация по типу, цене, стране. Пагинация и сортировка.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card tour-card h-100 text-center p-4">
                <div class="mb-3">
                    <svg width="40" height="40" fill="none" stroke="var(--primary)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 3h18v18H3zM3 9h18M9 21V9"/></svg>
                </div>
                <h5 class="fw-bold">Бронирование</h5>
                <p class="text-muted small mb-0">Онлайн-бронирование с отслеживанием статуса заявки.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card tour-card h-100 text-center p-4">
                <div class="mb-3">
                    <svg width="40" height="40" fill="none" stroke="var(--primary)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                </div>
                <h5 class="fw-bold">Избранное</h5>
                <p class="text-muted small mb-0">Сохраняйте понравившиеся туры для быстрого доступа.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card tour-card h-100 text-center p-4">
                <div class="mb-3">
                    <svg width="40" height="40" fill="none" stroke="var(--primary)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                </div>
                <h5 class="fw-bold">Отзывы</h5>
                <p class="text-muted small mb-0">Отзывы и оценки с визуальным рейтингом.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card tour-card h-100 text-center p-4">
                <div class="mb-3">
                    <svg width="40" height="40" fill="none" stroke="var(--primary)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
                </div>
                <h5 class="fw-bold">Чат</h5>
                <p class="text-muted small mb-0">Общение с поддержкой в реальном времени.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card tour-card h-100 text-center p-4">
                <div class="mb-3">
                    <svg width="40" height="40" fill="none" stroke="var(--primary)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
                </div>
                <h5 class="fw-bold">Отчёты</h5>
                <p class="text-muted small mb-0">Экспорт данных в Excel для аналитики.</p>
            </div>
        </div>
    </div>

    <!-- Роли -->
    <h2 class="fw-bold text-center mb-4">Роли пользователей</h2>
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card tour-card h-100 text-center p-4">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;background:var(--primary-light);color:var(--primary)">
                    <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <h5 class="fw-bold">Турист</h5>
                <p class="text-muted small mb-0">Просмотр, бронирование, отзывы, избранное, чат.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card tour-card h-100 text-center p-4">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;background:var(--primary-light);color:var(--primary)">
                    <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M20 8v6M23 11h-6"/></svg>
                </div>
                <h5 class="fw-bold">Менеджер</h5>
                <p class="text-muted small mb-0">Управление турами, бронированиями, чат поддержки.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card tour-card h-100 text-center p-4">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;background:var(--primary-light);color:var(--primary)">
                    <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h5 class="fw-bold">Администратор</h5>
                <p class="text-muted small mb-0">Полное управление контентом и пользователями.</p>
            </div>
        </div>
    </div>

    <div class="text-center">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-5">На главную</a>
    </div>
</div>
