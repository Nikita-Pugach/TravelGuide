@{
    ViewData["Title"] = "Главная";
    var popularTours = ViewBag.PopularTours as List<TravelGuide.Models.Entities.Tour>;
}

<!-- Hero Section -->
<section class="hero-section text-center">
    <div class="container position-relative">
        <h1>Откройте мир с TravelGuide</h1>
        <p class="lead">Найдите идеальный тур для незабываемого путешествия</p>
        <a asp-controller="Tours" asp-action="Index" class="btn btn-light btn-lg mt-3">
            Смотреть туры
        </a>
    </div>
</section>

<!-- Search Card -->
<div class="container">
    <div class="search-card">
        <form asp-controller="Tours" asp-action="Index" method="get">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Поиск</label>
                    <input type="text" name="search" class="form-control" placeholder="Название или описание тура...">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Тип тура</label>
                    <select name="tourType" class="form-select">
                        <option value="">Все типы</option>
                        <option value="0">Пляжный</option>
                        <option value="1">Экскурсионный</option>
                        <option value="2">Комбинированный</option>
                        <option value="3">Оздоровительный</option>
                        <option value="4">Круиз</option>
                        <option value="5">Приключения</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Макс. цена</label>
                    <input type="number" name="maxPrice" class="form-control" placeholder="₽">
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Найти</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Popular Tours Section -->
@if (popularTours != null && popularTours.Any())
{
    <section class="py-5">
        <div class="container">
            <h2 class="text-center mb-5">Популярные туры</h2>
            <div class="row g-4">
                @foreach (var tour in popularTours)
                {
                    var avgRating = tour.Reviews != null && tour.Reviews.Any() 
                        ? tour.Reviews.Average(r => r.Rating) 
                        : 0;
                    var reviewCount = tour.Reviews?.Count ?? 0;
                    
                    <div class="col-md-6 col-lg-3">
                        <div class="card h-100 tour-card border-0">
                            @if (!string.IsNullOrEmpty(tour.PhotoUrl))
                            {
                                <img src="@tour.PhotoUrl" class="card-img-top" alt="@tour.Name" style="height: 200px; object-fit: cover; border-radius: 12px 12px 0 0;">
                            }
                            else
                            {
                                <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px; border-radius: 12px 12px 0 0;">
                                    <span style="font-size: 3rem;">🏝️</span>
                                </div>
                            }
                            <div class="card-body">
                                <h5 class="card-title text-truncate">@tour.Name</h5>
                                <p class="text-muted small mb-2">
                                    @if (tour.Country != null)
                                    {
                                        <span>@tour.Country.Name</span>
                                    }
                                </p>
                                <div class="d-flex align-items-center mb-2">
                                    @if (reviewCount > 0)
                                    {
                                        <span class="star-rating">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= Math.Round(avgRating))
                                                {
                                                    <span>★</span>
                                                }
                                                else
                                                {
                                                    <span class="empty">★</span>
                                                }
                                            }
                                        </span>
                                        <span class="text-muted small ms-2">(@reviewCount)</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Нет отзывов</span>
                                    }
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="price-tag">@tour.Price.ToString("N0") ₽</span>
                                    <span class="duration-badge">@tour.Duration дн.</span>
                                </div>
                            </div>
                            <div class="card-footer bg-white border-0 pt-0">
                                <a asp-controller="Tours" asp-action="Details" asp-route-id="@tour.Id" class="btn btn-outline-primary w-100">
                                    Подробнее
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-4">
                <a asp-controller="Tours" asp-action="Index" class="btn btn-primary">
                    Все туры →
                </a>
            </div>
        </div>
    </section>
}

<!-- Features Section -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-5">Почему выбирают нас?</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="icon">🌍</div>
                    <h4>Большой выбор туров</h4>
                    <p class="text-muted">Более 100 направлений по всему миру</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="icon">💰</div>
                    <h4>Лучшие цены</h4>
                    <p class="text-muted">Сравниваем цены от разных агентств</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="icon">⭐</div>
                    <h4>Честные отзывы</h4>
                    <p class="text-muted">Реальные отзывы реальных туристов</p>
                </div>
            </div>
        </div>
    </div>
</section>