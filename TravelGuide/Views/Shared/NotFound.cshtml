@{
    ViewData["Title"] = "Страница не найдена";
    Layout = "_Layout";
}

<section class="hero-section text-center">
    <div class="container position-relative">
        <h1 style="font-size:6rem;font-weight:800;margin-bottom:0">404</h1>
        <p class="lead mb-0">Страница не найдена</p>
    </div>
</section>

<div class="container py-5 text-center">
    <div class="card tour-card mx-auto" style="max-width:500px">
        <div class="card-body p-5">
            <svg width="64" height="64" fill="none" stroke="var(--primary)" stroke-width="1.5" viewBox="0 0 24 24" class="mb-4">
                <path d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3 class="fw-bold mb-3">Упс! Такой страницы нет</h3>
            <p class="text-muted mb-4">Возможно, страница была перемещена или вы перешли по неверной ссылке.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">На главную</a>
        </div>
    </div>
</div>
