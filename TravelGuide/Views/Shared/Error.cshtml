@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<h1 class="text-danger">Ошибка.</h1>
<h2 class="text-danger">При обработке запроса произошла ошибка.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>ID запроса:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Режим разработки</h3>
<p>
    Переключение в среду <strong>Development</strong> отобразит подробную информацию об ошибке.
</p>
<p>
    <strong>Среду Development не нужно включать на продакшене.</strong>
    Она может показать конфиденциальные данные из ошибок. Для отладки включите среду <strong>Development</strong>, установив переменную окружения <strong>ASPNETCORE_ENVIRONMENT</strong> в значение <strong>Development</strong> и перезапустив приложение.
</p>
