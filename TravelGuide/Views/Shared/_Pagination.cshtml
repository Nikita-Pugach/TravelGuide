@model TravelGuide.ViewModels.PaginationViewModel

@if (Model.TotalPages > 1)
{
    <nav aria-label="Пагинация" class="mt-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="text-muted small">
                Показано @((Model.CurrentPage - 1) * Model.PageSize + 1)&#8211;@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalItems)) из @Model.TotalItems
            </div>
            <ul class="pagination mb-0">
                @if (Model.HasPreviousPage)
                {
                    <li class="page-item">
                         <a class="page-link" href="@Url.Action(Model.Action, Model.Controller, new RouteValueDictionary(Model.RouteValues!.Select(kv => new KeyValuePair<string, object?>(kv.Key, kv.Value))) { ["page"] = Model.CurrentPage - 1 })" aria-label="Назад">
                            <span aria-hidden="true">&#8592;</span>
                        </a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled">
                        <span class="page-link"><span aria-hidden="true">&#8592;</span></span>
                    </li>
                }

                @{
                    var startPage = Math.Max(1, Model.CurrentPage - 2);
                    var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                    
                    if (startPage > 1)
                    {
                        <li class="page-item">
                             <a class="page-link" href="@Url.Action(Model.Action, Model.Controller, new RouteValueDictionary(Model.RouteValues!.Select(kv => new KeyValuePair<string, object?>(kv.Key, kv.Value))) { ["page"] = 1 })">1</a>
                        </li>
                        if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                        }
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <li class="page-item active">
                            <span class="page-link">@i</span>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                             <a class="page-link" href="@Url.Action(Model.Action, Model.Controller, new RouteValueDictionary(Model.RouteValues!.Select(kv => new KeyValuePair<string, object?>(kv.Key, kv.Value))) { ["page"] = i })">@i</a>
                        </li>
                    }
                }

                @{
                    if (endPage < Model.TotalPages)
                    {
                        if (endPage < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                        }
                        <li class="page-item">
                             <a class="page-link" href="@Url.Action(Model.Action, Model.Controller, new RouteValueDictionary(Model.RouteValues!.Select(kv => new KeyValuePair<string, object?>(kv.Key, kv.Value))) { ["page"] = Model.TotalPages })">@Model.TotalPages</a>
                        </li>
                    }
                }

                @if (Model.HasNextPage)
                {
                    <li class="page-item">
                         <a class="page-link" href="@Url.Action(Model.Action, Model.Controller, new RouteValueDictionary(Model.RouteValues!.Select(kv => new KeyValuePair<string, object?>(kv.Key, kv.Value))) { ["page"] = Model.CurrentPage + 1 })" aria-label="Вперёд">
                            <span aria-hidden="true">&#8594;</span>
                        </a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled">
                        <span class="page-link"><span aria-hidden="true">&#8594;</span></span>
                    </li>
                }
            </ul>
        </div>
    </nav>
}