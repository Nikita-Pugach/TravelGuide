@model TravelGuide.ViewModels.CreateChatViewModel

@{
    ViewData["Title"] = "Новое сообщение";
}

<div class="container py-3">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card tour-card">
                <div class="card-body p-4">
                    <h4 class="mb-3" style="font-weight: 600;">Начать новый чат</h4>
                    
                    <div class="alert alert-info mb-3">
                        Наш менеджер ответит на ваше сообщение в ближайшее время!
                    </div>

                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="FirstMessage" class="form-label">Ваше сообщение</label>
                            <textarea asp-for="FirstMessage" class="form-control" rows="4" 
                                      placeholder="Здравствуйте! Меня интересуют туры в Турцию..."
                                      required maxlength="5000"></textarea>
                            <span asp-validation-for="FirstMessage" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                            <button type="submit" class="btn btn-primary">Отправить</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
