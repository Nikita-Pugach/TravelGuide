@model TravelGuide.ViewModels.ChatConversationViewModel

@{
    ViewData["Title"] = $"Чат с {Model.UserName}";
}

<div class="container py-3">
    <div class="card tour-card">
        <!-- Заголовок чата -->
        <div class="card-header d-flex justify-content-between align-items-center py-3" 
             style="background: var(--primary); color: white; border-radius: 12px 12px 0 0;">
            <div class="d-flex align-items-center">
                <a asp-action="Index" class="btn btn-sm me-3" style="background: rgba(255,255,255,0.2); color: white; border: none;">
                    Назад
                </a>
                <div class="me-2">
                    @if (!string.IsNullOrEmpty(Model.UserAvatar))
                    {
                        <img src="@Model.UserAvatar" class="rounded-circle" style="width: 38px; height: 38px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle d-flex align-items-center justify-content-center" 
                             style="width: 38px; height: 38px; background: rgba(255,255,255,0.2); color: white; font-weight: 600; font-size: 0.9rem;">
                            @Model.UserName.FirstOrDefault()
                        </div>
                    }
                </div>
                <div>
                    <h6 class="mb-0" style="font-weight: 600;">@Model.UserName</h6>
                    <small style="opacity: 0.8;">
                        @if (Model.Status == ChatStatus.Active)
                        {
                            <span>Активен</span>
                        }
                        else
                        {
                            <span>Закрыт</span>
                        }
                    </small>
                </div>
            </div>
            @if (Model.Status == ChatStatus.Active)
            {
                <form asp-action="Close" asp-route-id="@Model.ChatId" method="post">
                    <button type="submit" class="btn btn-sm" style="background: rgba(255,255,255,0.2); color: white; border: none;">
                        Закрыть чат
                    </button>
                </form>
            }
        </div>

        <!-- Сообщения -->
        <div class="card-body messages-container" style="height: 420px; overflow-y: auto; background: var(--bg-light);" id="messagesContainer">
            @if (!Model.Messages.Any())
            {
                <div class="text-center text-muted py-5">
                    <h5>Начните общение!</h5>
                    <p>Напишите первое сообщение менеджеру</p>
                </div>
            }
            else
            {
                @foreach (var msg in Model.Messages)
                {
                    <div class="message mb-3 @(msg.IsMyMessage ? "text-end" : "")">
                        <div class="d-inline-block rounded-3 p-2 px-3" 
                             style="max-width: 70%; @(msg.IsMyMessage ? "background: var(--primary); color: white;" : "background: white; border: 1px solid var(--border-color);")">
                            @if (!msg.IsMyMessage)
                            {
                                <small class="d-block mb-1" style="color: var(--text-muted); font-weight: 500;">@msg.SenderName</small>
                            }
                            <p class="mb-1">@msg.Text</p>
                            <small style="@(msg.IsMyMessage ? "opacity: 0.7;" : "color: var(--text-muted);")">
                                @msg.Timestamp.ToString("dd.MM HH:mm")
                                @if (msg.IsMyMessage)
                                {
                                    <span class="ms-1">@(msg.IsRead ? "✓✓" : "✓")</span>
                                }
                            </small>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Форма отправки -->
        @if (Model.Status == ChatStatus.Active)
        {
            <div class="card-footer py-3" style="background: white; border-top: 1px solid var(--border-color);">
                <form asp-action="SendMessage" method="post" id="messageForm">
                    <input type="hidden" name="ChatId" value="@Model.ChatId" />
                    <div class="d-flex gap-2">
                        <input type="text" name="Text" class="form-control" 
                               placeholder="Введите сообщение..." required maxlength="5000" id="messageInput" />
                        <button type="submit" class="btn btn-primary px-3">Отправить</button>
                    </div>
                </form>
            </div>
        }
        else
        {
            <div class="card-footer text-center py-3" style="background: var(--bg-light); border-top: 1px solid var(--border-color);">
                <span class="text-muted">Чат закрыт</span>
                <a asp-action="Create" class="btn btn-outline-primary btn-sm ms-2">Создать новый чат</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const container = document.getElementById('messagesContainer');
            container.scrollTop = container.scrollHeight;
        });
        
        const chatId = @Model.ChatId;
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chathub")
            .build();
        
        connection.on("ReceiveMessage", function(message) {
            const container = document.getElementById('messagesContainer');
            const isMyMessage = message.senderId === '@Context.Session.GetInt32("UserId")'.toString();
            
            const messageDiv = document.createElement('div');
            messageDiv.className = 'message mb-3 ' + (isMyMessage ? 'text-end' : '');
            messageDiv.innerHTML = `
                <div class="d-inline-block rounded-3 p-2 px-3" style="max-width: 70%; ${isMyMessage ? 'background: var(--primary); color: white;' : 'background: white; border: 1px solid var(--border-color);'}">
                    <p class="mb-1">${escapeHtml(message.text)}</p>
                    <small style="${isMyMessage ? 'opacity: 0.7;' : 'color: var(--text-muted);'}">${message.timestamp}</small>
                </div>
            `;
            container.appendChild(messageDiv);
            container.scrollTop = container.scrollHeight;
        });
        
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        connection.start().then(function() {
            connection.invoke("JoinChat", chatId).catch(function(err) {
                console.error(err.toString());
            });
        }).catch(function(err) {
            console.error(err.toString());
        });
        
        document.getElementById('messageForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const input = document.getElementById('messageInput');
            const text = input.value.trim();
            
            if (text) {
                connection.invoke("SendMessage", chatId, text, false).catch(function(err) {
                    console.error(err.toString());
                });
                input.value = '';
            }
        });
    </script>
}
