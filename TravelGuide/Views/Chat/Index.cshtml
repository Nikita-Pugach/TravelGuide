@model TravelGuide.ViewModels.ChatListViewModel

@{
    ViewData["Title"] = "Мои сообщения";
    var isManager = User.IsInRole("Manager") || User.IsInRole("Admin");
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-chat-dots me-2"></i>@(isManager ? "Все чаты" : "Мои сообщения")</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Новый чат
        </a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info">@TempData["Message"]</div>
    }

    @if (!Model.Chats.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-chat-square-text display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">У вас пока нет сообщений</h4>
            <p class="text-muted">Начните общение с нашим менеджером!</p>
            <a asp-action="Create" class="btn btn-primary mt-2">
                <i class="bi bi-chat-dots me-1"></i> Написать сообщение
            </a>
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var chat in Model.Chats)
            {
                <a asp-action="Conversation" asp-route-id="@chat.ChatId" 
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        <div class="avatar-placeholder me-3 bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" 
                             style="width: 48px; height: 48px; font-size: 20px;">
                            @if (!string.IsNullOrEmpty(chat.UserAvatar))
                            {
                                <img src="@chat.UserAvatar" class="rounded-circle" style="width: 48px; height: 48px; object-fit: cover;" />
                            }
                            else
                            {
                                <span>@chat.UserName.FirstOrDefault()</span>
                            }
                        </div>
                        <div>
                            <h6 class="mb-1">@chat.UserName</h6>
                            <small class="text-muted text-truncate d-inline-block" style="max-width: 250px;">
                                @chat.LastMessage
                            </small>
                            <br />
                            <small class="text-muted">
                                @chat.LastMessageTime.ToString("dd.MM HH:mm")
                                @if (!chat.HasManager && isManager)
                                {
                                    <span class="badge bg-warning text-dark ms-1">Ожидает ответа</span>
                                }
                            </small>
                        </div>
                    </div>
                    <div>
                        @if (chat.UnreadCount > 0)
                        {
                            <span class="badge bg-danger rounded-pill">@chat.UnreadCount</span>
                        }
                        @if (chat.Status == ChatStatus.Closed)
                        {
                            <span class="badge bg-secondary ms-1">Закрыт</span>
                        }
                    </div>
                </a>
            }
        </div>
    }
</div>