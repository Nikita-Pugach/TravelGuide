@model TravelGuide.ViewModels.ChatListViewModel

@{
    ViewData["Title"] = "Мои сообщения";
    var isManager = User.IsInRole("Manager") || User.IsInRole("Admin");
}

<div class="container py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 style="font-weight: 600;">@(isManager ? "Все чаты" : "Мои сообщения")</h2>
        <a asp-action="Create" class="btn btn-primary">Новый чат</a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info">@TempData["Message"]</div>
    }

    @if (!Model.Chats.Any())
    {
        <div class="card tour-card">
            <div class="card-body text-center py-5">
                <h4 class="text-muted mb-2">У вас пока нет сообщений</h4>
                <p class="text-muted">Начните общение с нашим менеджером!</p>
                <a asp-action="Create" class="btn btn-primary mt-2">Написать сообщение</a>
            </div>
        </div>
    }
    else
    {
        <div class="card tour-card">
            <div class="list-group list-group-flush">
                @foreach (var chat in Model.Chats)
                {
                    <a asp-action="Conversation" asp-route-id="@chat.ChatId" 
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3"
                       style="border-color: var(--border-color);">
                        <div class="d-flex align-items-center">
                            <div class="me-3 flex-shrink-0">
                                @if (!string.IsNullOrEmpty(chat.UserAvatar))
                                {
                                    <img src="@chat.UserAvatar" class="rounded-circle" style="width: 44px; height: 44px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="rounded-circle d-flex align-items-center justify-content-center" 
                                         style="width: 44px; height: 44px; background: var(--primary); color: white; font-weight: 600; font-size: 1rem;">
                                        @chat.UserName.FirstOrDefault()
                                    </div>
                                }
                            </div>
                            <div class="min-width-0">
                                <h6 class="mb-1" style="font-weight: 600;">@chat.UserName</h6>
                                <small class="text-muted d-block text-truncate" style="max-width: 280px;">
                                    @chat.LastMessage
                                </small>
                                <small class="text-muted">
                                    @chat.LastMessageTime.ToString("dd.MM HH:mm")
                                    @if (!chat.HasManager && isManager)
                                    {
                                        <span class="badge" style="background: #fff3cd; color: #856404; margin-left: 4px;">Ожидает</span>
                                    }
                                </small>
                            </div>
                        </div>
                        <div class="flex-shrink-0">
                            @if (chat.UnreadCount > 0)
                            {
                                <span class="badge rounded-pill" style="background: var(--primary);">@chat.UnreadCount</span>
                            }
                            @if (chat.Status == ChatStatus.Closed)
                            {
                                <span class="badge ms-1" style="background: var(--bg-gray); color: var(--text-muted);">Закрыт</span>
                            }
                        </div>
                    </a>
                }
            </div>
        </div>
    }
</div>
