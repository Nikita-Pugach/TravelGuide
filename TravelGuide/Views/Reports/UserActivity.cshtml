@model TravelGuide.Services.UserActivityReport
@{
    ViewData["Title"] = "Активность пользователей";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Активность пользователей</h2>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
            <form asp-action="ExportUserActivityExcel" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                <button type="submit" class="btn btn-success">Скачать Excel</button>
            </form>
        </div>
    </div>

    <!-- Фильтр -->
    <div class="card tour-card mb-4">
        <div class="card-body">
            <form asp-action="UserActivity" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Дата от</label>
                    <input type="date" name="dateFrom" class="form-control"
                           value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Дата до</label>
                    <input type="date" name="dateTo" class="form-control"
                           value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">Фильтровать</button>
                    <a asp-action="UserActivity" class="btn btn-outline-secondary">Сбросить</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Основная статистика -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@Model.TotalUsers</div>
                    <p class="text-muted mb-0">Пользователей</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@Model.NewUsers</div>
                    <p class="text-muted mb-0">Новых за период</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@Model.TotalReviews</div>
                    <p class="text-muted mb-0">Отзывов</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@Model.TotalChats</div>
                    <p class="text-muted mb-0">Чатов</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Дополнительная статистика -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@Model.ApprovedReviews</div>
                    <p class="text-muted mb-0">Опубликованных отзывов</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@Model.ActiveChats</div>
                    <p class="text-muted mb-0">Активных чатов</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@Model.TotalBookings</div>
                    <p class="text-muted mb-0">Бронирований</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Регистрации по месяцам -->
    @if (Model.RegistrationsByMonth.Any())
    {
        <div class="card tour-card">
            <div class="card-body">
                <h5 class="mb-3">Регистрации по месяцам</h5>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Месяц</th>
                                <th>Количество</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.RegistrationsByMonth)
                            {
                                <tr>
                                    <td>@m.MonthName @m.Year</td>
                                    <td>@m.Count</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
