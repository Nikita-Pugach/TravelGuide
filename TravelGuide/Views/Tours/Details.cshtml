@model TravelGuide.Models.Entities.Tour
@using TravelGuide.ViewModels
@{
    ViewData["Title"] = Model.Name;
    var sightsWithCoords = Model.TourSights?.Where(ts => ts.Sight?.Latitude.HasValue == true && ts.Sight?.Longitude.HasValue == true).ToList();
    var hotelsWithCoords = Model.TourHotels?.Where(th => th.Hotel?.Latitude.HasValue == true && th.Hotel?.Longitude.HasValue == true).ToList();
    var hasMapData = (sightsWithCoords?.Any() ?? false) || (hotelsWithCoords?.Any() ?? false);
}

<div class="container">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Туры</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>
    
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">@Model.Name</h3>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h5 class="text-muted">📍 Страна</h5>
                            <p class="fs-5">@Model.Country?.Name</p>
                        </div>
                        <div class="col-md-6">
                            <h5 class="text-muted">📅 Длительность</h5>
                            <p class="fs-5">@Model.Duration дней</p>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h5 class="text-muted">💰 Цена</h5>
                            <p class="fs-4 text-primary fw-bold">@Model.Price.ToString("N0") ₽</p>
                        </div>
                        <div class="col-md-6">
                            <h5 class="text-muted">🏷️ Тип тура</h5>
                            <p class="fs-5"><span class="badge bg-secondary">@Model.TourType</span></p>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <hr />
                        <h5>Описание</h5>
                        <p>@Model.Description</p>
                    }
                    
                    @if (Model.TourHotels != null && Model.TourHotels.Any())
                    {
                        <hr />
                        <h5>🏨 Отели</h5>
                        <div class="row">
                            @foreach (var th in Model.TourHotels)
                            {
                                <div class="col-md-6 mb-2">
                                    <div class="card">
                                        <div class="card-body py-2">
                                            <strong>@th.Hotel?.Name</strong>
                                            <br><small class="text-muted">@th.Hotel?.City?.Name</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    
                    @if (Model.TourSights != null && Model.TourSights.Any())
                    {
                        <hr />
                        <h5>🏛️ Достопримечательности</h5>
                        <div class="row">
                            @foreach (var ts in Model.TourSights)
                            {
                                <div class="col-md-6 mb-2">
                                    <div class="card">
                                        <div class="card-body py-2">
                                            <strong>@ts.Sight?.Name</strong>
                                            @if (!string.IsNullOrEmpty(ts.Sight?.Address))
                                            {
                                                <br><small class="text-muted">@ts.Sight.Address</small>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    
                    @if (hasMapData)
                    {
                        <hr />
                        <h5>🗺️ Карта</h5>
                        <div id="tourMap" style="height: 400px; border-radius: 10px; overflow: hidden;"></div>
                    }
                </div>
            </div>
            
            @using TravelGuide.Models.Entities
            @{
                var approvedReviews = Model.Reviews?.Where(r => r.Status == ReviewStatus.Approved).OrderByDescending(r => r.Date).ToList() ?? new List<Review>();
                var avgRating = approvedReviews.Any() ? Math.Round(approvedReviews.Average(r => r.Rating), 1) : 0;
            }
            
            <!-- Сообщения -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Отзывы -->
            <div class="card shadow">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">💬 Отзывы</h5>
                    @if (approvedReviews.Any())
                    {
                        <span class="badge bg-warning text-dark fs-6">
                            ⭐ @avgRating.ToString("0.0") (@approvedReviews.Count отзывов)
                        </span>
                    }
                </div>
                <div class="card-body">
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        <div class="card bg-light mb-4">
                            <div class="card-body">
                                <h6 class="card-title">Оставить отзыв</h6>
                                <form asp-action="Create" asp-controller="Reviews" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="TourId" value="@Model.Id" />
                                    <div class="mb-3">
                                        <label class="form-label">Оценка</label>
                                        <div class="star-rating-input">
                                            @for (int i = 5; i >= 1; i--)
                                            {
                                                <input type="radio" name="Rating" value="@i" id="star@(i)" @(i == 5 ? "checked" : "") class="d-none" />
                                                <label for="star@(i)" class="star-label" title="@i звёзд">★</label>
                                            }
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Ваш отзыв</label>
                                        <textarea name="Text" class="form-control" rows="3" placeholder="Поделитесь впечатлениями..." required minlength="10"></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-primary">Отправить на модерацию</button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-4">
                            <a asp-controller="Account" asp-action="Login">Войдите</a>, чтобы оставить отзыв
                        </div>
                    }
                    
                    @if (!approvedReviews.Any())
                    {
                        <p class="text-muted text-center">Отзывов пока нет. Будьте первым!</p>
                    }
                    else
                    {
                        @foreach (var review in approvedReviews)
                        {
                            <div class="border-bottom pb-3 mb-3">
                                <div class="d-flex justify-content-between">
                                    <strong>@review.User?.FullName</strong>
                                    <small class="text-muted">@review.Date.ToString("dd.MM.yyyy")</small>
                                </div>
                                <div class="mb-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="@(i <= review.Rating ? "text-warning" : "text-secondary")">★</span>
                                    }
                                </div>
                                <p class="mb-0">@review.Text</p>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            @if (Model.Agency != null)
            {
                <div class="card shadow mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">🏢 Агентство</h5>
                    </div>
                    <div class="card-body">
                        <h6>@Model.Agency.Name</h6>
                        @if (!string.IsNullOrEmpty(Model.Agency.Description))
                        {
                            <p class="text-muted small">@Model.Agency.Description</p>
                        }
                        <p class="mb-0">
                            <strong>Контакты:</strong><br>
                            @Model.Agency.ContactInfo
                        </p>
                        @if (Model.Agency.Rating > 0)
                        {
                            <p class="mt-2 mb-0">
                                <strong>Рейтинг:</strong>
                                <span class="text-warning">@Model.Agency.Rating ★</span>
                            </p>
                        }
                    </div>
                </div>
            }
            
            <div class="card shadow">
                <div class="card-body">
                    <h5 class="mb-3">Действия</h5>
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        @if (ViewBag.IsFavorite == true)
                        {
                            <form asp-action="RemoveFromFavorites" asp-route-id="@Model.Id" method="post" class="d-grid mb-2">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger">💔 Убрать из избранного</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="AddToFavorites" asp-route-id="@Model.Id" method="post" class="d-grid mb-2">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-success">❤️ В избранное</button>
                            </form>
                        }
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary d-grid mb-2">Войдите, чтобы добавить в избранное</a>
                    }
                    <a asp-action="Index" class="btn btn-secondary d-grid">← К списку туров</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (hasMapData)
    {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            (function() {
                var sights = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((sightsWithCoords ?? new List<TravelGuide.Models.Entities.TourSight>()).Select(ts => new { name = ts.Sight?.Name ?? "", lat = ts.Sight?.Latitude, lng = ts.Sight?.Longitude, address = ts.Sight?.Address ?? "" }).ToList()));
                var hotels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((hotelsWithCoords ?? new List<TravelGuide.Models.Entities.TourHotel>()).Select(th => new { name = th.Hotel?.Name ?? "", lat = th.Hotel?.Latitude, lng = th.Hotel?.Longitude, stars = th.Hotel?.Stars }).ToList()));
                
                var allPoints = [];
                sights.forEach(s => { if (s.lat && s.lng) allPoints.push(s); });
                hotels.forEach(h => { if (h.lat && h.lng) allPoints.push(h); });
                
                if (allPoints.length === 0) return;
                
                var map = L.map('tourMap').setView([allPoints[0].lat, allPoints[0].lng], 12);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© OpenStreetMap'
                }).addTo(map);
                
                var markers = [];
                
                sights.forEach(function(s) {
                    var marker = L.marker([s.lat, s.lng])
                        .bindPopup('<strong>🏛️ ' + s.name + '</strong>' + (s.address ? '<br><small>' + s.address + '</small>' : ''));
                    markers.push(marker);
                    marker.addTo(map);
                });
                
                hotels.forEach(function(h) {
                    var hotelIcon = L.divIcon({
                        className: 'hotel-marker',
                        html: '<div style="background:#e74c3c;color:white;border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;font-size:14px;">🏨</div>',
                        iconSize: [30, 30],
                        iconAnchor: [15, 15]
                    });
                    var marker = L.marker([h.lat, h.lng], { icon: hotelIcon })
                        .bindPopup('<strong>🏨 ' + h.name + '</strong>' + (h.stars ? '<br><small>' + '⭐'.repeat(h.stars) + '</small>' : ''));
                    markers.push(marker);
                    marker.addTo(map);
                });
                
                if (markers.length > 0) {
                    var group = L.featureGroup(markers);
                    map.fitBounds(group.getBounds().pad(0.1));
                }
            })();
        </script>
    }
}