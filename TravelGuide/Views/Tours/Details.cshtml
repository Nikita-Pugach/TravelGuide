@model TravelGuide.Models.Entities.Tour
@using TravelGuide.ViewModels
@using TravelGuide.Models.Entities
@{
    ViewData["Title"] = Model.Name;
    var sightsWithCoords = Model.TourSights?.Where(ts => ts.Sight?.Latitude.HasValue == true && ts.Sight?.Longitude.HasValue == true).ToList();
    var hotelsWithCoords = Model.TourHotels?.Where(th => th.Hotel?.Latitude.HasValue == true && th.Hotel?.Longitude.HasValue == true).ToList();
    var hasMapData = (sightsWithCoords?.Any() ?? false) || (hotelsWithCoords?.Any() ?? false);
    var approvedReviews = Model.Reviews?.Where(r => r.Status == ReviewStatus.Approved).OrderByDescending(r => r.Date).ToList() ?? new List<Review>();
    var avgRating = approvedReviews.Any() ? Math.Round(approvedReviews.Average(r => r.Rating), 1) : 0;
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Туры</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>
    
    <div class="row g-4">
        <div class="col-lg-8">
            <!-- Фото тура -->
            @if (!string.IsNullOrEmpty(Model.PhotoUrl))
            {
                <div class="tour-photo mb-4">
                    <img src="@Model.PhotoUrl" alt="@Model.Name" class="img-fluid rounded-4 shadow">
                </div>
            }
            
            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h1 class="mb-0">@Model.Name</h1>
                <span class="badge @GetTourTypeBadgeClass(Model.TourType) fs-6">@Model.TourType.GetDisplayName()</span>
            </div>
            
            <div class="d-flex align-items-center mb-4">
                <span class="country-flag me-2">@Model.Country?.GetFlag()</span>
                <span class="text-muted">@Model.Country?.Name</span>
                <span class="text-muted ms-3">👁 @Model.ViewCount просмотров</span>
            </div>
            
            <!-- Рейтинг -->
            @if (approvedReviews.Any())
            {
                <div class="d-flex align-items-center mb-4">
                    <span class="star-rating me-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="@(i <= Math.Round(avgRating) ? "" : "empty")">★</span>
                        }
                    </span>
                    <span class="fw-bold">@avgRating</span>
                    <span class="text-muted ms-2">(@approvedReviews.Count отзывов)</span>
                </div>
            }
            
            <!-- Инфо-боксы -->
            <div class="row g-3 mb-4">
                <div class="col-md-3 col-6">
                    <div class="info-box text-center">
                        <div class="info-icon">💰</div>
                        <div class="info-value">@Model.Price.ToString("N0") ₽</div>
                        <div class="info-label">Цена</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="info-box text-center">
                        <div class="info-icon">📅</div>
                        <div class="info-value">@Model.Duration</div>
                        <div class="info-label">Дней</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="info-box text-center">
                        <div class="info-icon">🏨</div>
                        <div class="info-value">@(Model.TourHotels?.Count ?? 0)</div>
                        <div class="info-label">Отели</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="info-box text-center">
                        <div class="info-icon">🏛️</div>
                        <div class="info-value">@(Model.TourSights?.Count ?? 0)</div>
                        <div class="info-label">Достопримечательности</div>
                    </div>
                </div>
            </div>
            
            <!-- Описание -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Описание</h5>
                        <p class="mb-0">@Model.Description</p>
                    </div>
                </div>
            }
            
            <!-- Отели -->
            @if (Model.TourHotels != null && Model.TourHotels.Any())
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">🏨 Отели в туре</h5>
                        <div class="row g-3">
                            @foreach (var th in Model.TourHotels)
                            {
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center p-3 bg-light rounded">
                                        @if (!string.IsNullOrEmpty(th.Hotel?.PhotoUrl))
                                        {
                                            <img src="@th.Hotel.PhotoUrl" alt="@th.Hotel.Name" class="rounded me-3" style="width: 60px; height: 60px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary bg-opacity-25 rounded me-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">🏨</div>
                                        }
                                        <div>
                                            <strong class="d-block">@th.Hotel?.Name</strong>
                                            <small class="text-muted">@th.Hotel?.City?.Name</small>
                                            @if (th.Hotel?.Stars > 0)
                                            {
                                                <span class="text-warning small"> @("⭐".Repeat(th.Hotel.Stars))</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            
            <!-- Достопримечательности -->
            @if (Model.TourSights != null && Model.TourSights.Any())
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">🏛️ Достопримечательности</h5>
                        <div class="row g-3">
                            @foreach (var ts in Model.TourSights)
                            {
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center p-3 bg-light rounded">
                                        @if (!string.IsNullOrEmpty(ts.Sight?.PhotoUrl))
                                        {
                                            <img src="@ts.Sight.PhotoUrl" alt="@ts.Sight.Name" class="rounded me-3" style="width: 60px; height: 60px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary bg-opacity-25 rounded me-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">🏛️</div>
                                        }
                                        <div>
                                            <strong class="d-block">@ts.Sight?.Name</strong>
                                            @if (!string.IsNullOrEmpty(ts.Sight?.Address))
                                            {
                                                <small class="text-muted">@ts.Sight.Address</small>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            
            <!-- Карта -->
            @if (hasMapData)
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">🗺️ Карта маршрута</h5>
                        <div id="tourMap" style="height: 400px; border-radius: 10px; overflow: hidden;"></div>
                    </div>
                </div>
            }
            
            <!-- Сообщения -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Отзывы -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="card-title mb-0">💬 Отзывы</h5>
                        @if (approvedReviews.Any())
                        {
                            <span class="badge bg-warning text-dark">
                                ⭐ @avgRating.ToString("0.0") (@approvedReviews.Count)
                            </span>
                        }
                    </div>
                    
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        <div class="card bg-light mb-4">
                            <div class="card-body">
                                <h6 class="card-title">Оставить отзыв</h6>
                                <form asp-action="Create" asp-controller="Reviews" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="TourId" value="@Model.Id" />
                                    <div class="mb-3">
                                        <label class="form-label">Оценка</label>
                                        <div class="star-rating-input">
                                            @for (int i = 5; i >= 1; i--)
                                            {
                                                <input type="radio" name="Rating" value="@i" id="star@(i)" @(i == 5 ? "checked" : "") class="d-none" />
                                                <label for="star@(i)" class="star-label" title="@i звёзд">★</label>
                                            }
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Ваш отзыв</label>
                                        <textarea name="Text" class="form-control" rows="3" placeholder="Поделитесь впечатлениями..." required minlength="10"></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-primary">Отправить</button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-4">
                            <a asp-controller="Account" asp-action="Login">Войдите</a>, чтобы оставить отзыв
                        </div>
                    }
                    
                    @if (!approvedReviews.Any())
                    {
                        <p class="text-muted text-center py-4">Отзывов пока нет. Будьте первым!</p>
                    }
                    else
                    {
                        @foreach (var review in approvedReviews)
                        {
                            <div class="review-item">
                                <div class="d-flex">
                                    @if (!string.IsNullOrEmpty(review.User?.AvatarUrl))
                                    {
                                        <img src="@review.User.AvatarUrl" alt="@review.User.FullName" class="review-avatar">
                                    }
                                    else
                                    {
                                        <div class="review-avatar bg-primary text-white d-flex align-items-center justify-content-center">
                                            @(review.User?.FullName?.FirstOrDefault() ?? "?")
                                        </div>
                                    }
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <strong>@review.User?.FullName</strong>
                                            <small class="text-muted">@review.Date.ToString("dd.MM.yyyy")</small>
                                        </div>
                                        <div class="mb-2">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <span class="@(i <= review.Rating ? "text-warning" : "text-secondary")">★</span>
                                            }
                                        </div>
                                        <p class="mb-0">@review.Text</p>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        
        <!-- Боковая панель -->
        <div class="col-lg-4">
            @if (Model.Agency != null)
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">🏢 Агентство</h5>
                        <h6 class="fw-bold">@Model.Agency.Name</h6>
                        @if (!string.IsNullOrEmpty(Model.Agency.Description))
                        {
                            <p class="text-muted small">@Model.Agency.Description</p>
                        }
                        <p class="mb-0 small">
                            <strong>Контакты:</strong><br>
                            @Model.Agency.ContactInfo
                        </p>
                        @if (Model.Agency.Rating > 0)
                        {
                            <p class="mt-2 mb-0">
                                <strong>Рейтинг:</strong>
                                <span class="text-warning">@Model.Agency.Rating ★</span>
                            </p>
                        }
                    </div>
                </div>
            }
            
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-body">
                    <h5 class="mb-3">Действия</h5>
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        @if (ViewBag.IsFavorite == true)
                        {
                            <form asp-action="RemoveFromFavorites" asp-route-id="@Model.Id" method="post" class="d-grid mb-2">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger">💔 Убрать из избранного</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="AddToFavorites" asp-route-id="@Model.Id" method="post" class="d-grid mb-2">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success">❤️ В избранное</button>
                            </form>
                        }
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary d-grid mb-2">Войдите для избранного</a>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary d-grid">← К списку туров</a>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetTourTypeBadgeClass(TourType type) => type switch
    {
        TourType.Beach => "badge-beach",
        TourType.Excursion => "badge-excursion",
        TourType.Combined => "badge-combined",
        TourType.Health => "badge-health",
        TourType.Cruise => "badge-cruise",
        TourType.Adventure => "badge-adventure",
        _ => "bg-secondary"
    };
}

@section Scripts {
    @if (hasMapData)
    {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            (function() {
                var sights = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((sightsWithCoords ?? new List<TourSight>()).Select(ts => new { name = ts.Sight?.Name ?? "", lat = ts.Sight?.Latitude, lng = ts.Sight?.Longitude, address = ts.Sight?.Address ?? "" }).ToList()));
                var hotels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((hotelsWithCoords ?? new List<TourHotel>()).Select(th => new { name = th.Hotel?.Name ?? "", lat = th.Hotel?.Latitude, lng = th.Hotel?.Longitude, stars = th.Hotel?.Stars }).ToList()));
                
                var allPoints = [];
                sights.forEach(s => { if (s.lat && s.lng) allPoints.push(s); });
                hotels.forEach(h => { if (h.lat && h.lng) allPoints.push(h); });
                
                if (allPoints.length === 0) return;
                
                var map = L.map('tourMap').setView([allPoints[0].lat, allPoints[0].lng], 12);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© OpenStreetMap'
                }).addTo(map);
                
                var markers = [];
                
                sights.forEach(function(s) {
                    var marker = L.marker([s.lat, s.lng])
                        .bindPopup('<strong>🏛️ ' + s.name + '</strong>' + (s.address ? '<br><small>' + s.address + '</small>' : ''));
                    markers.push(marker);
                    marker.addTo(map);
                });
                
                hotels.forEach(function(h) {
                    var hotelIcon = L.divIcon({
                        className: 'hotel-marker',
                        html: '<div style="background:#e74c3c;color:white;border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;font-size:14px;">🏨</div>',
                        iconSize: [30, 30],
                        iconAnchor: [15, 15]
                    });
                    var marker = L.marker([h.lat, h.lng], { icon: hotelIcon })
                        .bindPopup('<strong>🏨 ' + h.name + '</strong>' + (h.stars ? '<br><small>' + '⭐'.repeat(h.stars) + '</small>' : ''));
                    markers.push(marker);
                    marker.addTo(map);
                });
                
                if (markers.length > 0) {
                    var group = L.featureGroup(markers);
                    map.fitBounds(group.getBounds().pad(0.1));
                }
            })();
        </script>
    }
}