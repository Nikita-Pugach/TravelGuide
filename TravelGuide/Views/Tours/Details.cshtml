@model TravelGuide.Models.Entities.Tour
@using TravelGuide.ViewModels
@using TravelGuide.Models.Entities
@{
    ViewData["Title"] = Model.Name;
    var sightsWithCoords = Model.TourSights?.Where(ts => ts.Sight?.Latitude.HasValue == true && ts.Sight?.Longitude.HasValue == true).ToList();
    var hotelsWithCoords = Model.TourHotels?.Where(th => th.Hotel?.Latitude.HasValue == true && th.Hotel?.Longitude.HasValue == true).ToList();
    var hasMapData = (sightsWithCoords?.Any() ?? false) || (hotelsWithCoords?.Any() ?? false);
    var approvedReviews = Model.Reviews?.Where(r => r.Status == ReviewStatus.Approved).OrderByDescending(r => r.Date).ToList() ?? new List<Review>();
    var avgRating = approvedReviews.Any() ? Math.Round(approvedReviews.Average(r => r.Rating), 1) : 0;
    var totalSights = Model.TourSights?.Count ?? 0;
    var totalHotels = Model.TourHotels?.Count ?? 0;
}

<style>
    .tour-hero {
        position: relative;
        height: 70vh;
        min-height: 500px;
        max-height: 700px;
        background: linear-gradient(135deg, var(--primary) 0%, #5ba4e5 100%);
        overflow: hidden;
    }
    .tour-hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        filter: brightness(0.6);
        transition: transform 0.3s ease;
    }
    .tour-hero:hover .tour-hero-bg {
        transform: scale(1.02);
    }
    .tour-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.5) 100%);
    }
    .tour-hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 3rem;
        color: white;
    }
    .tour-hero-content h1 {
        font-size: 2.8rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        text-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }
    .info-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        padding: 0.4rem 0.9rem;
        border-radius: 50px;
        font-size: 0.85rem;
        color: white;
        margin-right: 0.5rem;
        margin-bottom: 0.5rem;
    }
    .booking-sticky {
        position: sticky;
        top: 80px;
    }
    .booking-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        border: none;
        overflow: hidden;
    }
    .booking-card-header {
        background: linear-gradient(135deg, var(--primary) 0%, #5ba4e5 100%);
        color: white;
        padding: 1.5rem;
        text-align: center;
    }
    .booking-card-body {
        padding: 1.5rem;
    }
    .price-large {
        font-size: 2.2rem;
        font-weight: 700;
        color: white;
    }
    .section-divider {
        border: none;
        border-top: 1px solid var(--border-color);
        margin: 2rem 0;
    }
    .detail-section {
        margin-bottom: 2.5rem;
    }
    .detail-section-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .detail-section-title::before {
        content: '';
        width: 4px;
        height: 20px;
        background: var(--primary);
        border-radius: 2px;
    }
    .hotel-card-mini {
        background: var(--bg-light);
        border-radius: 12px;
        padding: 1rem;
        transition: all 0.2s ease;
        border: 1px solid transparent;
    }
    .hotel-card-mini:hover {
        border-color: var(--primary);
        box-shadow: 0 4px 12px rgba(74,144,217,0.15);
    }
    .review-card {
        background: white;
        border-radius: 12px;
        padding: 1.25rem;
        border: 1px solid var(--border-color);
        margin-bottom: 1rem;
        transition: all 0.2s ease;
    }
    .review-card:hover {
        box-shadow: var(--shadow);
    }
    .rating-bar {
        height: 8px;
        background: var(--bg-gray);
        border-radius: 4px;
        overflow: hidden;
        flex-grow: 1;
    }
    .rating-bar-fill {
        height: 100%;
        background: var(--warning);
        border-radius: 4px;
        transition: width 0.5s ease;
    }
    .route-day {
        display: flex;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .route-day-marker {
        width: 32px;
        height: 32px;
        background: var(--primary);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 0.85rem;
        flex-shrink: 0;
    }
    .cta-button {
        width: 100%;
        padding: 1rem;
        font-size: 1.05rem;
        font-weight: 600;
        border-radius: 12px;
        transition: all 0.3s ease;
    }
    .cta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(74,144,217,0.4);
    }
    .fade-in {
        animation: fadeIn 0.6s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s ease;
    }
    .back-link:hover {
        color: var(--primary);
    }
</style>

<!-- Hero -->
<section class="tour-hero">
    @if (!string.IsNullOrEmpty(Model.PhotoUrl))
    {
        <div class="tour-hero-bg" style="background-image: url('@Model.PhotoUrl')"></div>
    }
    <div class="tour-hero-overlay"></div>
    <div class="tour-hero-content">
        <div class="container">
            <a href="#" class="back-link text-white mb-3 d-inline-block" onclick="history.back(); return false;">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Назад
            </a>
            <h1>@Model.Name</h1>
            <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                <span class="info-chip">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    @Model.Country?.Name
                </span>
                <span class="info-chip">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    @Model.Duration дн.
                </span>
                <span class="info-chip">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                    @Model.TourType.GetDisplayName()
                </span>
                @if (approvedReviews.Any())
                {
                    <span class="info-chip">
                        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        @avgRating
                    </span>
                }
            </div>
            <div class="price-large">
                @Model.Price.ToString("N0") ₽
                <span style="font-size: 1rem; font-weight: 400; opacity: 0.8;">за человека</span>
            </div>
        </div>
    </div>
</section>

<!-- Контент -->
<div class="container py-5 fade-in">
    <div class="row g-5">

        <!-- Левая колонка -->
        <div class="col-lg-8">

            <!-- Статистика — компактная полоска -->
            <div class="d-flex flex-wrap justify-content-center gap-4 p-3 mb-4 rounded-3" style="background: var(--bg-white); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
                <div class="text-center px-3">
                    <div class="fw-bold" style="font-size:1.3rem;color:var(--primary)">@Model.Duration</div>
                    <div class="text-muted small">дней</div>
                </div>
                <div class="text-center px-3" style="border-left:1px solid var(--border-color)">
                    <div class="fw-bold" style="font-size:1.3rem;color:var(--primary)">@totalHotels</div>
                    <div class="text-muted small">отелей</div>
                </div>
                <div class="text-center px-3" style="border-left:1px solid var(--border-color)">
                    <div class="fw-bold" style="font-size:1.3rem;color:var(--primary)">@totalSights</div>
                    <div class="text-muted small">мест</div>
                </div>
                <div class="text-center px-3" style="border-left:1px solid var(--border-color)">
                    <div class="fw-bold" style="font-size:1.3rem;color:var(--primary)">@Model.ViewCount</div>
                    <div class="text-muted small">просмотров</div>
                </div>
            </div>

            <!-- Описание -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="detail-section">
                    <h3 class="detail-section-title">Описание</h3>
                    <p style="line-height: 1.9; color: var(--text-dark); font-size: 1.05rem;">@Model.Description</p>
                </div>
                <hr class="section-divider">
            }

            <!-- Маршрут -->
            @if (!string.IsNullOrEmpty(Model.Route))
            {
                <div class="detail-section">
                    <h3 class="detail-section-title">Маршрут</h3>
                    <div class="card tour-card">
                        <div class="card-body p-4">
                            @{
                                var days = Model.Route.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                                int dayNum = 1;
                            }
                            @foreach (var day in days)
                            {
                                <div class="route-day">
                                    <div class="route-day-marker">@dayNum</div>
                                    <div class="pt-1">
                                        <p class="mb-0" style="line-height: 1.7;">@day.Trim()</p>
                                    </div>
                                </div>
                                dayNum++;
                            }
                        </div>
                    </div>
                </div>
                <hr class="section-divider">
            }

            <!-- Отели -->
            @if (Model.TourHotels?.Any() == true)
            {
                <div class="detail-section">
                    <h3 class="detail-section-title">Отели</h3>
                    <div class="row g-3">
                        @foreach (var th in Model.TourHotels)
                        {
                            <div class="col-md-6">
                                <a asp-controller="Hotels" asp-action="Details" asp-route-id="@th.Hotel?.Id" class="text-decoration-none">
                                    <div class="hotel-card-mini h-100">
                                        <div class="d-flex align-items-center gap-3">
                                            @if (!string.IsNullOrEmpty(th.Hotel?.PhotoUrl))
                                            {
                                                <img src="@th.Hotel.PhotoUrl" class="rounded flex-shrink-0" style="width:72px;height:72px;object-fit:cover" />
                                            }
                                            else
                                            {
                                                <div class="rounded flex-shrink-0 d-flex align-items-center justify-content-center" style="width:72px;height:72px;background:var(--primary-light)">
                                                    <span class="text-primary fw-bold">H</span>
                                                </div>
                                            }
                                            <div class="min-width-0">
                                                <div class="fw-semibold text-truncate" style="color:var(--text-dark)">@th.Hotel?.Name</div>
                                                <div class="text-muted small mb-1">@th.Hotel?.City?.Name</div>
                                                @if (th.Hotel?.Stars > 0)
                                                {
                                                    <div class="text-warning small">@for(var i=0;i<th.Hotel.Stars;i++){<text>★</text>}</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                </div>
                <hr class="section-divider">
            }

            <!-- Достопримечательности -->
            @if (Model.TourSights?.Any() == true)
            {
                <div class="detail-section">
                    <h3 class="detail-section-title">Достопримечательности</h3>
                    <div class="row g-3">
                        @foreach (var ts in Model.TourSights)
                        {
                            <div class="col-md-6">
                                <a asp-controller="Sights" asp-action="Details" asp-route-id="@ts.Sight?.Id" class="text-decoration-none">
                                    <div class="hotel-card-mini h-100">
                                        <div class="d-flex align-items-center gap-3">
                                            @if (!string.IsNullOrEmpty(ts.Sight?.PhotoUrl))
                                            {
                                                <img src="@ts.Sight.PhotoUrl" class="rounded flex-shrink-0" style="width:72px;height:72px;object-fit:cover" />
                                            }
                                            else
                                            {
                                                <div class="rounded flex-shrink-0 d-flex align-items-center justify-content-center" style="width:72px;height:72px;background:var(--primary-light)">
                                                    <span class="text-primary fw-bold">S</span>
                                                </div>
                                            }
                                            <div class="min-width-0">
                                                <div class="fw-semibold text-truncate" style="color:var(--text-dark)">@ts.Sight?.Name</div>
                                                <div class="text-muted small">@ts.Sight?.Type.GetDisplayName()</div>
                                                @if (!string.IsNullOrEmpty(ts.Sight?.Address))
                                                {
                                                    <div class="text-muted small text-truncate" style="max-width:200px;">@ts.Sight.Address</div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                </div>
                <hr class="section-divider">
            }

            <!-- Карта -->
            @if (hasMapData)
            {
                <div class="detail-section">
                    <h3 class="detail-section-title">Карта маршрута</h3>
                    <div class="card tour-card">
                        <div class="card-body p-3">
                            <div id="tourMap" style="height:420px;border-radius:12px;overflow:hidden"></div>
                        </div>
                    </div>
                </div>
                <hr class="section-divider">
            }

            <!-- Агентство -->
            @if (Model.Agency != null)
            {
                <div class="detail-section">
                    <h3 class="detail-section-title">Туроператор</h3>
                    <div class="card tour-card">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center gap-4">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:64px;height:64px;background:linear-gradient(135deg,var(--primary),#5ba4e5);color:white;font-weight:700;font-size:1.4rem;box-shadow:0 4px 12px rgba(74,144,217,0.3)">
                                    @Model.Agency.Name.FirstOrDefault()
                                </div>
                                <div>
                                    <h5 class="mb-1 fw-bold">@Model.Agency.Name</h5>
                                    @if (!string.IsNullOrEmpty(Model.Agency.Description))
                                    {
                                        <p class="text-muted mb-1 small">@Model.Agency.Description</p>
                                    }
                                    <div class="text-muted small">
                                        @Model.Agency.ContactInfo
                                        @if (Model.Agency.Rating > 0)
                                        {
                                            <span class="ms-2">
                                                <span class="text-warning fw-bold">@Model.Agency.Rating</span>
                                                <span class="text-muted">★</span>
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <hr class="section-divider">
            }

            <!-- Сообщения -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4">@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }

            <!-- Отзывы -->
            <div class="detail-section">
                <h3 class="detail-section-title">Отзывы</h3>

                @if (Context.Session.GetInt32("UserId") != null)
                {
                    <div class="card tour-card mb-4">
                        <div class="card-body p-4">
                            <h6 class="mb-3 fw-semibold">Оставить отзыв</h6>
                            <form asp-action="Create" asp-controller="Reviews" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="TourId" value="@Model.Id" />
                                <div class="mb-3">
                                    <div class="star-rating-input">
                                        @for (int i = 5; i >= 1; i--)
                                        {
                                            <input type="radio" name="Rating" value="@i" id="star@(i)" @(i == 5 ? "checked" : "") class="d-none" />
                                            <label for="star@(i)" class="star-label">★</label>
                                        }
                                    </div>
                                </div>
                                <textarea name="Text" class="form-control mb-3" rows="3" placeholder="Поделитесь впечатлениями о туре..." required minlength="10"></textarea>
                                <button type="submit" class="btn btn-primary">Отправить</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card tour-card mb-4">
                        <div class="card-body p-4 text-center">
                            <p class="mb-2 text-muted">Хотите оставить отзыв?</p>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Войдите</a>
                        </div>
                    </div>
                }

                @if (approvedReviews.Any())
                {
                    <!-- Средний рейтинг -->
                    <div class="card tour-card mb-4">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center gap-4">
                                <div class="text-center">
                                    <div style="font-size:3rem;font-weight:700;color:var(--primary);line-height:1">@avgRating</div>
                                    <div class="text-muted small">из 5</div>
                                </div>
                                <div class="flex-grow-1">
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        var count = approvedReviews.Count(r => r.Rating == i);
                                        var pct = approvedReviews.Count > 0 ? (double)count / approvedReviews.Count * 100 : 0;
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <span class="small" style="width:12px;color:var(--warning)">★</span>
                                            <span class="small text-muted" style="width:8px">@i</span>
                                            <div class="rating-bar">
                                                <div class="rating-bar-fill" style="width:@pct%"></div>
                                            </div>
                                            <span class="small text-muted" style="width:24px;text-align:right">@count</span>
                                        </div>
                                    }
                                </div>
                                <div class="text-center">
                                    <div class="text-muted small">@approvedReviews.Count</div>
                                    <div class="text-muted small">отзывов</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (!approvedReviews.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="mb-3" style="opacity:0.3"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                        <p>Отзывов пока нет. Будьте первым!</p>
                    </div>
                }
                else
                {
                    @foreach (var review in approvedReviews)
                    {
                        <div class="review-card">
                            <div class="d-flex gap-3">
                                @if (!string.IsNullOrEmpty(review.User?.AvatarUrl))
                                {
                                    <img src="@review.User.AvatarUrl" class="rounded-circle flex-shrink-0" style="width:44px;height:44px;object-fit:cover" />
                                }
                                else
                                {
                                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;background:linear-gradient(135deg,var(--primary),#5ba4e5);color:white;font-size:.9rem;font-weight:600">
                                        @(review.User?.FullName?.FirstOrDefault() ?? '?')
                                    </div>
                                }
                                <div class="min-width-0 flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <strong style="color:var(--text-dark)">@review.User?.FullName</strong>
                                        <small class="text-muted">@review.Date.ToString("dd.MM.yyyy")</small>
                                    </div>
                                    <div class="mb-2">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span style="color:@(i <= review.Rating ? "var(--warning)" : "var(--text-light)");font-size:.9rem">★</span>
                                        }
                                    </div>
                                    <p class="mb-0" style="line-height:1.7;">@review.Text</p>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

        </div>

        <!-- Правая колонка — Booking -->
        <div class="col-lg-4">
            <div class="booking-sticky">
                <div class="booking-card mb-4">
                    <div class="booking-card-header">
                        <div class="price-large">@Model.Price.ToString("N0") ₽</div>
                        <div style="opacity:0.8;font-size:0.9rem;">за человека</div>
                        @if (approvedReviews.Any())
                        {
                            <div class="mt-2">
                                <span class="text-warning">★</span>
                                <strong>@avgRating</strong>
                                <span style="opacity:0.8;font-size:0.85rem;">(@approvedReviews.Count)</span>
                            </div>
                        }
                    </div>
                    <div class="booking-card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid var(--border-color)">
                                <span class="text-muted small">Страна</span>
                                <span class="fw-semibold small">@Model.Country?.Name</span>
                            </div>
                            <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid var(--border-color)">
                                <span class="text-muted small">Длительность</span>
                                <span class="fw-semibold small">@Model.Duration дн.</span>
                            </div>
                            <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid var(--border-color)">
                                <span class="text-muted small">Тип</span>
                                <span class="fw-semibold small">@Model.TourType.GetDisplayName()</span>
                            </div>
                            <div class="d-flex justify-content-between py-2">
                                <span class="text-muted small">Туроператор</span>
                                <span class="fw-semibold small">@Model.Agency?.Name</span>
                            </div>
                        </div>

                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <a asp-controller="Bookings" asp-action="Create" asp-route-id="@Model.Id" class="btn btn-primary cta-button mb-2">
                                Забронировать тур
                            </a>
                            @if (ViewBag.IsFavorite == true)
                            {
                                <form asp-action="RemoveFromFavorites" asp-route-id="@Model.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger w-100" style="border-radius:12px;">
                                        Убрать из избранного
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="AddToFavorites" asp-route-id="@Model.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-primary w-100" style="border-radius:12px;">
                                        В избранное
                                    </button>
                                </form>
                            }
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-primary cta-button">
                                Войдите для бронирования
                            </a>
                        }
                    </div>
                </div>

                <div class="text-center">
                    <a asp-action="Index" class="back-link">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                        Ко всем турам
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @if (hasMapData)
    {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            (function() {
                var sights = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((sightsWithCoords ?? new List<TourSight>()).Select(ts => new { name = ts.Sight?.Name ?? "", lat = ts.Sight?.Latitude, lng = ts.Sight?.Longitude, address = ts.Sight?.Address ?? "" }).ToList()));
                var hotels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((hotelsWithCoords ?? new List<TourHotel>()).Select(th => new { name = th.Hotel?.Name ?? "", lat = th.Hotel?.Latitude, lng = th.Hotel?.Longitude, stars = th.Hotel?.Stars }).ToList()));
                var allPoints = [];
                sights.forEach(function(s){ if(s.lat&&s.lng) allPoints.push(s); });
                hotels.forEach(function(h){ if(h.lat&&h.lng) allPoints.push(h); });
                if(allPoints.length===0) return;
                var map = L.map('tourMap').setView([allPoints[0].lat,allPoints[0].lng],12);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap'}).addTo(map);
                sights.forEach(function(s){
                    L.marker([s.lat,s.lng]).bindPopup('<b>'+s.name+'</b>'+(s.address?'<br><small>'+s.address+'</small>':'')).addTo(map);
                });
                hotels.forEach(function(h){
                    L.marker([h.lat,h.lng]).bindPopup('<b>'+h.name+'</b>'+(h.stars?'<br><small>'+'★'.repeat(h.stars)+'</small>':'')).addTo(map);
                });
            })();
        </script>
    }
}
