@{
    ViewData["Title"] = "Админ-панель";
}

<div class="container">
    <h2 class="mb-4">Администрирование</h2>
    
    <!-- Статистика -->
    <div class="row g-3 mb-4">
        <div class="col">
            <a asp-action="Users" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center">
                        <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.UsersCount</div>
                        <p class="text-muted mb-0">Пользователей</p>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col">
            <a asp-action="Tours" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center">
                        <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.ToursCount</div>
                        <p class="text-muted mb-0">Туров</p>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col">
            <a asp-action="Reviews" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center">
                        <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.ReviewsCount</div>
                        <p class="text-muted mb-0">Отзывов</p>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col">
            <a asp-action="Bookings" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center">
                        <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.BookingsCount</div>
                        <p class="text-muted mb-0">Бронирований</p>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col">
            <a asp-controller="Chat" asp-action="Index" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center">
                        <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.ChatsActiveCount</div>
                        <p class="text-muted mb-0">Чатов</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
    
    <!-- Быстрые ссылки -->
    <div class="row g-3">
        <div class="col-md-4">
            <a asp-action="Countries" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-4">
                        <h5 class="mb-1">Справочники</h5>
                        <small class="text-muted">Страны, города, отели, агентства</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Reports" asp-action="Index" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-4">
                        <h5 class="mb-1">Отчёты</h5>
                        <small class="text-muted">Статистика и аналитика</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-action="Users" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-4">
                        <h5 class="mb-1">Пользователи</h5>
                        <small class="text-muted">Управление и блокировка</small>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
