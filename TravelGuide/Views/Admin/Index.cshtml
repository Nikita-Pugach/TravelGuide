@{
    ViewData["Title"] = "Админ-панель";
}

<div class="container">
    <h2 class="mb-4">🎛️ Административная панель</h2>
    
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card bg-primary text-white h-100">
                <div class="card-body text-center">
                    <h3>@ViewBag.UsersCount</h3>
                    <p class="mb-0">👥 Пользователей</p>
                </div>
                <div class="card-footer">
                    <a asp-action="Users" class="text-white text-decoration-none">Управление →</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3 mb-4">
            <div class="card bg-success text-white h-100">
                <div class="card-body text-center">
                    <h3>@ViewBag.ToursCount</h3>
                    <p class="mb-0">🗺️ Туры</p>
                </div>
                <div class="card-footer">
                    <a asp-action="Tours" class="text-white text-decoration-none">Управление →</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3 mb-4">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body text-center">
                    <h3>@ViewBag.ReviewsPendingCount</h3>
                    <p class="mb-0">⏳ Отзывов на модерации</p>
                </div>
                <div class="card-footer">
                    <a asp-action="Reviews" asp-route-status="Pending" class="text-dark text-decoration-none">Модерация →</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3 mb-4">
            <div class="card bg-info text-white h-100">
                <div class="card-body text-center">
                    <h3>@ViewBag.ChatsActiveCount</h3>
                    <p class="mb-0">💬 Активных чатов</p>
                </div>
                <div class="card-footer">
                    <a asp-controller="Chat" asp-action="Index" class="text-white text-decoration-none">Чаты →</a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">📚 Справочники</h5>
                </div>
                <div class="card-body">
                    <div class="list-group">
                        <a asp-action="Tours" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            🗺️ Туры
                            <span class="badge bg-primary">CRUD</span>
                        </a>
                        <a asp-action="Countries" class="list-group-item list-group-item-action">
                            🌍 Страны
                        </a>
                        <a asp-action="Cities" class="list-group-item list-group-item-action">
                            🏙️ Города
                        </a>
                        <a asp-action="Agencies" class="list-group-item list-group-item-action">
                            🏢 Агентства
                        </a>
                        <a asp-action="Hotels" class="list-group-item list-group-item-action">
                            🏨 Отели
                        </a>
                        <a asp-action="Sights" class="list-group-item list-group-item-action">
                            🏛️ Достопримечательности
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">⚡ Быстрые действия</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-action="Reviews" asp-route-status="Pending" class="btn btn-warning">
                            ⏳ Модерация отзывов
                            @if (ViewBag.ReviewsPendingCount > 0)
                            {
                                <span class="badge bg-dark">@ViewBag.ReviewsPendingCount</span>
                            }
                        </a>
                        <a asp-action="Users" class="btn btn-primary">
                            👥 Управление пользователями
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>