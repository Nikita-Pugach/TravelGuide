@{
    ViewData["Title"] = "Админ-панель";
}

<div class="container">
    <h2 class="mb-4" style="font-weight: 600;">Администрирование</h2>
    
    <!-- Статистика -->
    <div class="row g-3 mb-5">
        <div class="col-md-3">
            <div class="card h-100" style="border-left: 4px solid var(--primary);">
                <div class="card-body text-center py-3">
                    <div style="font-weight: 700; color: var(--primary); font-size: 1.8rem;">@ViewBag.UsersCount</div>
                    <p class="text-muted mb-2">Пользователей</p>
                    <a asp-action="Users" class="btn btn-primary btn-sm w-100">Управление</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card h-100" style="border-left: 4px solid #198754;">
                <div class="card-body text-center py-3">
                    <div style="font-weight: 700; color: #198754; font-size: 1.8rem;">@ViewBag.ToursCount</div>
                    <p class="text-muted mb-2">Туров</p>
                    <a asp-action="Tours" class="btn btn-primary btn-sm w-100" style="background: #198754; border-color: #198754;">Управление</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card h-100" style="border-left: 4px solid #ffc107;">
                <div class="card-body text-center py-3">
                    <div style="font-weight: 700; color: #ffc107; font-size: 1.8rem;">@ViewBag.ReviewsPendingCount</div>
                    <p class="text-muted mb-2">На модерации</p>
                    <a asp-action="Reviews" asp-route-status="Pending" class="btn btn-primary btn-sm w-100" style="background: #ffc107; border-color: #ffc107; color: #000;">Модерация</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card h-100" style="border-left: 4px solid #dc3545;">
                <div class="card-body text-center py-3">
                    <div style="font-weight: 700; color: #dc3545; font-size: 1.8rem;">@ViewBag.ChatsActiveCount</div>
                    <p class="text-muted mb-2">Активных чатов</p>
                    <a asp-controller="Chat" asp-action="Index" class="btn btn-primary btn-sm w-100" style="background: #dc3545; border-color: #dc3545;">Чаты</a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Разделы -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100" style="border-top: 3px solid var(--primary);">
                <div class="card-body">
                    <h5 class="card-title" style="font-weight: 600;">Справочники</h5>
                    <div class="list-group list-group-flush">
                        <a asp-action="Countries" class="list-group-item list-group-item-action">Страны</a>
                        <a asp-action="Cities" class="list-group-item list-group-item-action">Города</a>
                        <a asp-action="Hotels" class="list-group-item list-group-item-action">Отели</a>
                        <a asp-action="Sights" class="list-group-item list-group-item-action">Достопримечательности</a>
                        <a asp-action="Agencies" class="list-group-item list-group-item-action">Агентства</a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100" style="border-top: 3px solid #198754;">
                <div class="card-body">
                    <h5 class="card-title" style="font-weight: 600;">Управление</h5>
                    <div class="d-grid gap-2">
                        <a asp-action="Tours" class="btn btn-primary">Туры</a>
                        <a asp-action="Users" class="btn btn-primary">Пользователи</a>
                        <a asp-action="Reviews" class="btn btn-primary">Отзывы</a>
                        <a asp-action="Bookings" class="btn btn-primary">Бронирования</a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100" style="border-top: 3px solid #ffc107;">
                <div class="card-body">
                    <h5 class="card-title" style="font-weight: 600;">Отчёты</h5>
                    <p class="text-muted small">Статистика и аналитика по платформе</p>
                    <div class="d-grid gap-2">
                        <a asp-controller="Reports" asp-action="Index" class="btn btn-primary" style="background: #ffc107; border-color: #ffc107; color: #000;">Открыть отчёты</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
