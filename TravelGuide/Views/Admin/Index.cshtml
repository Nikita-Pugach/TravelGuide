@{
    ViewData["Title"] = "Админ-панель";
}

<div class="container">
    <h2 class="mb-4">Администрирование</h2>
    
    <!-- Статистика -->
    <div class="row g-3 mb-5">
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.UsersCount</div>
                    <p class="text-muted mb-0">Пользователей</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pt-0">
                    <a asp-action="Users" class="btn btn-outline-primary btn-sm w-100">Управление</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.ToursCount</div>
                    <p class="text-muted mb-0">Туров</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pt-0">
                    <a asp-action="Tours" class="btn btn-outline-primary btn-sm w-100">Управление</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.ReviewsPendingCount</div>
                    <p class="text-muted mb-0">На модерации</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pt-0">
                    <a asp-action="Reviews" asp-route-status="Pending" class="btn btn-outline-primary btn-sm w-100">Модерация</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.ChatsActiveCount</div>
                    <p class="text-muted mb-0">Активных чатов</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pt-0">
                    <a asp-controller="Chat" asp-action="Index" class="btn btn-outline-primary btn-sm w-100">Чаты</a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Разделы -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card tour-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Справочники</h5>
                    <div class="list-group list-group-flush">
                        <a asp-action="Countries" class="list-group-item list-group-item-action">Страны</a>
                        <a asp-action="Cities" class="list-group-item list-group-item-action">Города</a>
                        <a asp-action="Hotels" class="list-group-item list-group-item-action">Отели</a>
                        <a asp-action="Sights" class="list-group-item list-group-item-action">Достопримечательности</a>
                        <a asp-action="Agencies" class="list-group-item list-group-item-action">Агентства</a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card tour-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Управление</h5>
                    <div class="d-grid gap-2">
                        <a asp-action="Tours" class="btn btn-outline-primary">Туры</a>
                        <a asp-action="Users" class="btn btn-outline-primary">Пользователи</a>
                        <a asp-action="Reviews" class="btn btn-outline-primary">Отзывы</a>
                        <a asp-action="Bookings" class="btn btn-outline-primary">Бронирования</a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card tour-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Отчёты</h5>
                    <p class="text-muted small">Статистика и аналитика по платформе</p>
                    <div class="d-grid gap-2">
                        <a asp-controller="Reports" asp-action="Index" class="btn btn-primary">Открыть отчёты</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
