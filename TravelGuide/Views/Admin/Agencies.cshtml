@model IEnumerable<TravelGuide.Models.Entities.Agency>
@{
    ViewData["Title"] = "Управление агентствами";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Управление агентствами</h2>
        <a asp-action="CreateAgency" class="btn btn-primary">+ Добавить агентство</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Лого</th>
                            <th>Название</th>
                            <th>Рейтинг</th>
                            <th>Контакт</th>
                            <th>Туров</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var agency in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(agency.LogoUrl))
                                    {
                                        <img src="@agency.LogoUrl" alt="@agency.Name" style="width: 60px; height: 40px; object-fit: cover; border-radius: 4px;">
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center" style="width: 60px; height: 40px; border-radius: 4px; border: 1px solid #dee2e6;">
                                            <span class="text-muted small">Нет</span>
                                        </div>
                                    }
                                </td>
                                <td><strong>@agency.Name</strong></td>
                                <td>
                                    @if (agency.Rating.HasValue)
                                    {
                                        <span class="text-warning">@agency.Rating.Value.ToString("F1") ★</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>@(agency.ContactInfo ?? "-")</td>
                                <td>@(agency.Tours?.Count ?? 0)</td>
                                <td>
                                    <a asp-action="EditAgency" asp-route-id="@agency.Id" class="btn btn-sm btn-outline-primary">Изм.</a>
                                    <form asp-action="DeleteAgency" asp-route-id="@agency.Id" method="post" class="d-inline" onsubmit="return confirm('Удалить агентство?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Удал.</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>