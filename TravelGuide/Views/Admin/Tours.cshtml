@model IEnumerable<TravelGuide.Models.Entities.Tour>
@using TravelGuide.Models.Entities

@{
    ViewData["Title"] = "Управление турами";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Управление турами</h2>
        <a asp-action="CreateTour" class="btn btn-primary">+ Добавить тур</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var tour in Model)
            {
                var badgeClass = tour.TourType switch
                {
                    TourType.Beach => "badge-beach",
                    TourType.Excursion => "badge-excursion",
                    TourType.Combined => "badge-combined",
                    TourType.Health => "badge-health",
                    TourType.Cruise => "badge-cruise",
                    TourType.Adventure => "badge-adventure",
                    _ => "bg-secondary"
                };

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 tour-card border-0">
                        @if (!string.IsNullOrEmpty(tour.PhotoUrl))
                        {
                            <img src="@tour.PhotoUrl" class="card-img-top" alt="@tour.Name" style="height: 180px; object-fit: cover; border-radius: 12px 12px 0 0;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 180px; border-radius: 12px 12px 0 0;">
                                <span class="text-muted">Нет фото</span>
                            </div>
                        }
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title text-truncate mb-0">@tour.Name</h5>
                                <span class="badge @badgeClass ms-2">@tour.TourType.GetDisplayName()</span>
                            </div>
                            <p class="text-muted small mb-2">
                                <span class="country-flag">@tour.Country?.GetFlag()</span>
                                @tour.Country?.Name
                            </p>
                            <p class="text-muted small mb-2">Агентство: @tour.Agency?.Name</p>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="price-tag">@tour.Price.ToString("N0") &#8381;</span>
                                <span class="duration-badge">@tour.Duration дн.</span>
                            </div>
                            <p class="text-muted small mb-0">Создан: @tour.CreatedDate.ToString("dd.MM.yyyy")</p>
                            @if (tour.IsSeasonal)
                            {
                                <span class="badge bg-info mt-2">Сезонный</span>
                            }
                        </div>
                        <div class="card-footer bg-white border-0 pt-0">
                            <div class="d-flex gap-2">
                                <a asp-action="EditTour" asp-route-id="@tour.Id" class="btn btn-outline-primary btn-sm flex-grow-1">Изм.</a>
                                <a asp-controller="Tours" asp-action="Details" asp-route-id="@tour.Id" class="btn btn-outline-secondary btn-sm flex-grow-1">Смотр.</a>
                                <form asp-action="DeleteTour" asp-route-id="@tour.Id" method="post" class="d-inline flex-grow-1"
                                      onsubmit="return confirm('Удалить тур @tour.Name?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100">Удал.</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <p class="text-muted">Туры не найдены. Добавьте первый тур!</p>
            <a asp-action="CreateTour" class="btn btn-primary">Добавить тур</a>
        </div>
    }
</div>
