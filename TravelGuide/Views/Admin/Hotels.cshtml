@model IEnumerable<TravelGuide.Models.Entities.Hotel>
@{
    ViewData["Title"] = "Управление отелями";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Управление отелями</h1>
        <a asp-action="CreateHotel" class="btn btn-primary">+ Добавить отель</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Фото</th>
                            <th>Название</th>
                            <th>Город</th>
                            <th>Звёзды</th>
                            <th>Питание</th>
                            <th>Цена/ночь</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var hotel in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(hotel.PhotoUrl))
                                    {
                                        <img src="@hotel.PhotoUrl" alt="@hotel.Name" style="width: 60px; height: 40px; object-fit: cover; border-radius: 4px;">
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center" style="width: 60px; height: 40px; border-radius: 4px;">🏨</div>
                                    }
                                </td>
                                <td>@hotel.Name</td>
                                <td>@hotel.City?.Name, @hotel.City?.Country?.Name</td>
                                <td>
                                    @for (int i = 0; i < hotel.Stars; i++)
                                    {
                                        <span class="text-warning">★</span>
                                    }
                                </td>
                                <td><span class="badge bg-info">@hotel.MealType</span></td>
                                <td>@(hotel.PricePerNight?.ToString("N0") ?? "-") ₽</td>
                                <td>
                                    <a asp-action="EditHotel" asp-route-id="@hotel.Id" class="btn btn-sm btn-outline-primary">✏️</a>
                                    <form asp-action="DeleteHotel" asp-route-id="@hotel.Id" method="post" class="d-inline" onsubmit="return confirm('Удалить отель?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>