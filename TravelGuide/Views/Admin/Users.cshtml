@model IEnumerable<TravelGuide.Models.Entities.User>
@using TravelGuide.Models.Entities
@{
    ViewData["Title"] = "Управление пользователями";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Управление пользователями</h2>
        <a asp-action="Index" class="btn btn-secondary">Назад</a>
    </div>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    <!-- Статистика -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center py-3">
                    <div class="price-tag mb-1" style="font-size: 1.25rem;">@Model.Count()</div>
                    <p class="text-muted mb-0 small">Всего</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center py-3">
                    <div class="price-tag mb-1" style="font-size: 1.25rem;">@Model.Count(u => !u.IsBlocked)</div>
                    <p class="text-muted mb-0 small">Активных</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center py-3">
                    <div class="price-tag mb-1" style="font-size: 1.25rem;">@Model.Count(u => u.Role == UserRole.Admin)</div>
                    <p class="text-muted mb-0 small">Администраторов</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center py-3">
                    <div class="price-tag mb-1" style="font-size: 1.25rem;">@Model.Count(u => u.Role == UserRole.Manager)</div>
                    <p class="text-muted mb-0 small">Менеджеров</p>
                </div>
            </div>
        </div>
    </div>
    
    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var user in Model)
            {
                var roleBadgeClass = user.Role switch
                {
                    UserRole.Admin => "bg-danger",
                    UserRole.Manager => "bg-warning text-dark",
                    UserRole.Tourist => "bg-primary",
                    _ => "bg-secondary"
                };
                
                var roleText = user.Role switch
                {
                    UserRole.Admin => "Администратор",
                    UserRole.Manager => "Менеджер",
                    UserRole.Tourist => "Турист",
                    _ => "Гость"
                };
                
                var initials = user.FullName.Length >= 2 
                    ? user.FullName.Substring(0, 2).ToUpper() 
                    : user.FullName.ToUpper();

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 tour-card border-0">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="avatar-circle me-3" style="width: 50px; height: 50px; font-size: 1.1rem;">
                                    <span class="avatar-initials">@initials</span>
                                </div>
                                <div class="flex-grow-1 min-width-0">
                                    <h6 class="mb-0 text-truncate">@user.FullName</h6>
                                    <small class="text-muted text-truncate d-block">@user.Email</small>
                                </div>
                            </div>
                            
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <span class="badge @roleBadgeClass">@roleText</span>
                                @if (user.IsBlocked)
                                {
                                    <span class="badge bg-secondary">Заблокирован</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Активен</span>
                                }
                            </div>
                            
                            <div class="text-muted small mb-2">
                                @if (!string.IsNullOrEmpty(user.Agency?.Name))
                                {
                                    <div>Агентство: @user.Agency.Name</div>
                                }
                                <div>Регистрация: @user.RegistrationDate.ToString("dd.MM.yyyy")</div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pt-0">
                            @if (user.Role != UserRole.Admin || user.Id == Context.Session.GetInt32("UserId"))
                            {
                                <!-- Смена роли -->
                                <form asp-action="ChangeRole" asp-route-id="@user.Id" method="post" class="mb-2">
                                    @Html.AntiForgeryToken()
                                    <div class="input-group input-group-sm">
                                        <select name="role" class="form-select form-select-sm">
                                            <option value="Tourist" selected="@(user.Role == UserRole.Tourist)">Турист</option>
                                            <option value="Manager" selected="@(user.Role == UserRole.Manager)">Менеджер</option>
                                            <option value="Admin" selected="@(user.Role == UserRole.Admin)">Администратор</option>
                                        </select>
                                        <button type="submit" class="btn btn-outline-primary btn-sm">Сменить</button>
                                    </div>
                                </form>
                            }

                            @if (user.Role != UserRole.Admin)
                            {
                                <form asp-action="ToggleUserBlock" asp-route-id="@user.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    @if (!user.IsBlocked)
                                    {
                                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">Заблокировать</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-outline-success btn-sm w-100">Разблокировать</button>
                                    }
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small d-block text-center py-1">Администратор</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <p class="text-muted">Пользователей нет</p>
        </div>
    }
</div>