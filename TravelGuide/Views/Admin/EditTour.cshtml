@model TravelGuide.Models.Entities.Tour
@{
    ViewData["Title"] = "Редактирование тура";
    var countries = ViewBag.Countries as IEnumerable<TravelGuide.Models.Entities.Country>;
    var agencies = ViewBag.Agencies as IEnumerable<TravelGuide.Models.Entities.Agency>;
    var hotels = ViewBag.Hotels as IEnumerable<TravelGuide.Models.Entities.Hotel>;
    var sights = ViewBag.Sights as IEnumerable<TravelGuide.Models.Entities.Sight>;
    var selectedHotels = ViewBag.SelectedHotels as List<int> ?? new List<int>();
    var selectedSights = ViewBag.SelectedSights as List<int> ?? new List<int>();
}

<div class="pb-5">
<form asp-action="EditTour" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="card tour-card mb-3">
        <div class="card-body p-3">
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Название тура *</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="TourType" class="form-label">Тип тура</label>
                    <select asp-for="TourType" class="form-select" asp-items="Html.GetEnumSelectList<TravelGuide.Models.Entities.TourType>()"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Price" class="form-label">Цена *</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" required />
                </div>
                <div class="col-md-4">
                    <label asp-for="Duration" class="form-label">Дней *</label>
                    <input asp-for="Duration" class="form-control" type="number" min="1" required />
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-4">
                    <label asp-for="CountryId" class="form-label">Страна</label>
                    <select asp-for="CountryId" class="form-select">
                        <option value="">-- Выберите --</option>
                        @foreach (var c in countries ?? Enumerable.Empty<TravelGuide.Models.Entities.Country>())
                        {
                            <option value="@c.Id" selected="@(Model.CountryId == c.Id)">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="AgencyId" class="form-label">Агентство</label>
                    <select asp-for="AgencyId" class="form-select">
                        <option value="">-- Выберите --</option>
                        @foreach (var a in agencies ?? Enumerable.Empty<TravelGuide.Models.Entities.Agency>())
                        {
                            <option value="@a.Id" selected="@(Model.AgencyId == a.Id)">@a.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="photo" class="form-label">Фото тура</label>
                    <input type="file" name="photo" id="photo" class="form-control" accept="image/*" />
                </div>
            </div>
            <div id="photoPreview" class="mt-2" style="display:none">
                <img id="previewImg" src="" class="rounded" style="max-height:120px" />
            </div>
            @if (!string.IsNullOrEmpty(Model.PhotoUrl))
            {
                <div class="mt-2">
                    <img src="@Model.PhotoUrl" class="rounded" style="max-height:120px" />
                </div>
            }
            <div class="row g-3 mt-1">
                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label">Дата начала</label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                </div>
                <div class="col-md-6">
                    <label asp-for="EndDate" class="form-label">Дата окончания</label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                </div>
            </div>
            <div class="mt-3">
                <label asp-for="Description" class="form-label">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>
            <div class="mt-3">
                <label asp-for="Route" class="form-label">Маршрут</label>
                <textarea asp-for="Route" class="form-control" rows="2" placeholder="День 1: ..."></textarea>
            </div>
        </div>
    </div>

    <div class="card tour-card mb-3">
        <div class="card-body p-3">
            <div class="form-check mb-2">
                <input asp-for="IsSeasonal" class="form-check-input" />
                <label asp-for="IsSeasonal" class="form-check-label">Сезонный тур</label>
            </div>
            <input asp-for="SeasonalMonths" class="form-control" placeholder="Месяцы: 6,7,8" />
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card tour-card h-100">
                <div class="card-body p-3">
                    <h6 class="mb-2 fw-bold">Отели</h6>
                    <div style="max-height:180px;overflow-y:auto">
                        @if (hotels?.Any() == true)
                        {
                            foreach (var h in hotels)
                            {
                                <div class="form-check mb-1">
                                    <input type="checkbox" name="selectedHotels" value="@h.Id" class="form-check-input" id="h_@h.Id" checked="@(selectedHotels.Contains(h.Id))" />
                                    <label class="form-check-label small" for="h_@h.Id">@h.Name <span class="text-muted">(@h.City?.Name)</span></label>
                                </div>
                            }
                        }
                        else { <p class="text-muted small mb-0">Нет</p> }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card tour-card h-100">
                <div class="card-body p-3">
                    <h6 class="mb-2 fw-bold">Достопримечательности</h6>
                    <div style="max-height:180px;overflow-y:auto">
                        @if (sights?.Any() == true)
                        {
                            foreach (var s in sights)
                            {
                                <div class="form-check mb-1">
                                    <input type="checkbox" name="selectedSights" value="@s.Id" class="form-check-input" id="s_@s.Id" checked="@(selectedSights.Contains(s.Id))" />
                                    <label class="form-check-label small" for="s_@s.Id">@s.Name <span class="text-muted">(@s.City?.Name)</span></label>
                                </div>
                            }
                        }
                        else { <p class="text-muted small mb-0">Нет</p> }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3 mb-4">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a asp-action="Tours" class="btn btn-outline-secondary">Отмена</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('photo').addEventListener('change', function(e) {
            var f = e.target.files[0];
            if (f) {
                var r = new FileReader();
                r.onload = function(e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('photoPreview').style.display = 'block';
                };
                r.readAsDataURL(f);
            }
        });
    </script>
}
</div>
