@model IEnumerable<TravelGuide.Models.Entities.Country>
@{
    ViewData["Title"] = "Управление странами";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Управление странами</h2>
        <a asp-action="CreateCountry" class="btn btn-primary">+ Добавить страну</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Фото</th>
                            <th>Название</th>
                            <th>Городов</th>
                            <th>Описание</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var country in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(country.PhotoUrl))
                                    {
                                        <img src="@country.PhotoUrl" alt="@country.Name" style="width: 60px; height: 40px; object-fit: cover; border-radius: 4px;">
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center" style="width: 60px; height: 40px; border-radius: 4px; border: 1px solid #dee2e6;">
                                            <small class="text-muted">@country.Name.Substring(0, Math.Min(2, country.Name.Length)).ToUpper()</small>
                                        </div>
                                    }
                                </td>
                                <td><strong>@country.Name</strong></td>
                                <td>@(country.Cities?.Count ?? 0)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(country.Description))
                                    {
                                        <span class="text-truncate d-inline-block" style="max-width: 200px;" title="@country.Description">
                                            @country.Description
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="EditCountry" asp-route-id="@country.Id" class="btn btn-sm btn-outline-primary">Изм.</a>
                                    <form asp-action="DeleteCountry" asp-route-id="@country.Id" method="post" class="d-inline" onsubmit="return confirm('Удалить страну?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Удал.</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>