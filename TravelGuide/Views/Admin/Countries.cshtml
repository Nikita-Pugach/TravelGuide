@model IEnumerable<TravelGuide.Models.Entities.Country>
@{
    ViewData["Title"] = "Управление странами";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🌍 Управление странами</h2>
    <a asp-action="CreateCountry" class="btn btn-primary">➕ Добавить страну</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="row">
    @foreach (var country in Model)
    {
        <div class="col-md-4 col-lg-3 mb-4">
            <div class="card h-100">
                @if (!string.IsNullOrEmpty(country.PhotoUrl))
                {
                    <img src="@country.PhotoUrl" class="card-img-top" alt="@country.Name" style="height: 120px; object-fit: cover;" />
                }
                else
                {
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 120px;">
                        <span style="font-size: 4rem;">@country.GetFlag()</span>
                    </div>
                }
                <div class="card-body">
                    <h5 class="card-title">@country.GetFlag() @country.Name</h5>
                    <p class="card-text small text-muted">Городов: @country.Cities?.Count ?? 0</p>
                    @if (!string.IsNullOrEmpty(country.Description))
                    {
                        <p class="card-text small">@(country.Description.Length > 100 ? country.Description.Substring(0, 100) + "..." : country.Description)</p>
                    }
                </div>
                <div class="card-footer bg-white">
                    <div class="btn-group btn-group-sm w-100">
                        <a asp-action="EditCountry" asp-route-id="@country.Id" class="btn btn-outline-primary">✏️</a>
                        <form asp-action="DeleteCountry" asp-route-id="@country.Id" method="post" style="display: inline;">
                            <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Удалить страну?')">🗑️</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted">Страны не найдены</p>
        <a asp-action="CreateCountry" class="btn btn-primary">Добавить страну</a>
    </div>
}