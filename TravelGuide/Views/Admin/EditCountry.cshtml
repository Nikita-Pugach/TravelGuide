@model TravelGuide.Models.Entities.Country
@{
    ViewData["Title"] = "Редактирование страны";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h4>✏️ Редактирование страны</h4>
            </div>
            <div class="card-body">
                <form asp-action="EditCountry" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Название *</label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Описание</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                    {
                        <div class="mb-3 text-center">
                            <img src="@Model.PhotoUrl" alt="@Model.Name" class="img-thumbnail" style="max-height: 150px;" />
                        </div>
                    }
                    
                    <div class="mb-3">
                        <label for="photo" class="form-label">Новое изображение</label>
                        <input type="file" name="photo" id="photo" class="form-control" accept="image/*" />
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">💾 Сохранить</button>
                        <a asp-action="Countries" class="btn btn-outline-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>