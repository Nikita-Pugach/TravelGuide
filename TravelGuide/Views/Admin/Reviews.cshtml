@model IEnumerable<TravelGuide.Models.Entities.Review>
@using TravelGuide.Models.Entities
@{
    ViewData["Title"] = "Модерация отзывов";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Модерация отзывов</h2>
        <a asp-action="Index" class="btn btn-secondary">Назад</a>
    </div>
    
    <!-- Фильтры -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        <a asp-action="Reviews" class="btn @(ViewBag.CurrentStatus == null ? "btn-outline-dark" : "btn-outline-secondary")">Все</a>
        <a asp-action="Reviews" asp-route-status="Pending" class="btn @(ViewBag.CurrentStatus?.ToString() == "Pending" ? "btn-outline-warning" : "btn-outline-secondary")">На модерации</a>
        <a asp-action="Reviews" asp-route-status="Approved" class="btn @(ViewBag.CurrentStatus?.ToString() == "Approved" ? "btn-outline-success" : "btn-outline-secondary")">Опубликованные</a>
        <a asp-action="Reviews" asp-route-status="Rejected" class="btn @(ViewBag.CurrentStatus?.ToString() == "Rejected" ? "btn-outline-danger" : "btn-outline-secondary")">Отклонённые</a>
    </div>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted">Нет отзывов для отображения</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var review in Model)
            {
                var statusBadgeClass = review.Status switch
                {
                    ReviewStatus.Pending => "badge-status-pending",
                    ReviewStatus.Approved => "badge-status-approved",
                    ReviewStatus.Rejected => "badge-status-rejected",
                    _ => "badge-role-guest"
                };
                
                var statusText = review.Status switch
                {
                    ReviewStatus.Pending => "На модерации",
                    ReviewStatus.Approved => "Опубликован",
                    ReviewStatus.Rejected => "Отклонён",
                    _ => "Неизвестно"
                };
                
                var itemName = "";
                var itemBadgeClass = "";
                if (review.Tour != null)
                {
                    itemName = review.Tour.Name;
                    itemBadgeClass = "badge-type-tour";
                }
                else if (review.Hotel != null)
                {
                    itemName = review.Hotel.Name;
                    itemBadgeClass = "badge-type-hotel";
                }
                else if (review.Sight != null)
                {
                    itemName = review.Sight.Name;
                    itemBadgeClass = "badge-type-sight";
                }
                
                var authorInitials = review.User?.FullName != null && review.User.FullName.Length >= 2
                    ? review.User.FullName.Substring(0, 2).ToUpper()
                    : "?";

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 tour-card border-0">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="avatar-circle me-3" style="width: 44px; height: 44px;">
                                    <span class="avatar-initials" style="font-size: 0.8rem;">@authorInitials</span>
                                </div>
                                <div class="flex-grow-1 min-width-0">
                                    <h6 class="mb-0 text-truncate">@(review.User?.FullName ?? "Аноним")</h6>
                                    <small class="text-muted">@review.Date.ToString("dd.MM.yyyy HH:mm")</small>
                                </div>
                                <span class="badge @statusBadgeClass ms-2">@statusText</span>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(itemName))
                            {
                                <div class="mb-2">
                                    <span class="badge @itemBadgeClass">@itemName</span>
                                </div>
                            }
                            
                            <div class="mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="@(i <= review.Rating ? "text-warning" : "text-secondary")">★</span>
                                }
                            </div>
                            
                            <p class="text-muted small mb-0" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                @review.Text
                            </p>
                        </div>
                        <div class="card-footer bg-white border-0 pt-0">
                            @if (review.Status == ReviewStatus.Pending)
                            {
                                <div class="d-flex gap-2">
                                    <form asp-action="ApproveReview" asp-route-id="@review.Id" method="post" class="flex-grow-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-success btn-sm w-100">Одобрить</button>
                                    </form>
                                    <form asp-action="RejectReview" asp-route-id="@review.Id" method="post" class="flex-grow-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">Отклонить</button>
                                    </form>
                                </div>
                            }
                            else if (review.Status == ReviewStatus.Rejected)
                            {
                                <form asp-action="ApproveReview" asp-route-id="@review.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-success btn-sm w-100">Опубликовать</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small d-block text-center py-1">Обработан</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>