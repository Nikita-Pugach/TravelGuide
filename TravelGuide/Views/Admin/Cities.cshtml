@model IEnumerable<TravelGuide.Models.Entities.City>
@{
    ViewData["Title"] = "Управление городами";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Управление городами</h2>
        <a asp-action="CreateCity" class="btn btn-primary">+ Добавить город</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Город</th>
                            <th>Страна</th>
                            <th>Отели</th>
                            <th>Достопримечательности</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var city in Model)
                        {
                            <tr>
                                <td><strong>@city.Name</strong></td>
                                <td>@city.Country?.GetFlag() @city.Country?.Name</td>
                                <td>@(city.Hotels?.Count ?? 0)</td>
                                <td>@(city.Sights?.Count ?? 0)</td>
                                <td>
                                    <a asp-action="EditCity" asp-route-id="@city.Id" class="btn btn-sm btn-outline-primary">Изм.</a>
                                    <form asp-action="DeleteCity" asp-route-id="@city.Id" method="post" class="d-inline" onsubmit="return confirm('Удалить город?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Удал.</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>