@model IEnumerable<TravelGuide.Models.Entities.City>
@{
    ViewData["Title"] = "Управление городами";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🏙️ Управление городами</h2>
    <a asp-action="CreateCity" class="btn btn-primary">➕ Добавить город</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Город</th>
                <th>Страна</th>
                <th>Отели</th>
                <th>Достопримечательности</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var city in Model)
            {
                <tr>
                    <td><strong>@city.Name</strong></td>
                    <td>@city.Country?.GetFlag() @city.Country?.Name</td>
                    <td>@(city.Hotels?.Count ?? 0)</td>
                    <td>@(city.Sights?.Count ?? 0)</td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a asp-action="EditCity" asp-route-id="@city.Id" class="btn btn-outline-primary">✏️</a>
                            <form asp-action="DeleteCity" asp-route-id="@city.Id" method="post" style="display: inline;">
                                <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Удалить город?')">🗑️</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted">Города не найдены</p>
        <a asp-action="CreateCity" class="btn btn-primary">Добавить город</a>
    </div>
}