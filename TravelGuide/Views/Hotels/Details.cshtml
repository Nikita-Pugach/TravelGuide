@model TravelGuide.Models.Entities.Hotel
@{
    ViewData["Title"] = Model.Name;
    var avgRating = Model.Reviews != null && Model.Reviews.Any() 
        ? Model.Reviews.Average(r => r.Rating) 
        : 0;
    var reviewCount = Model.Reviews?.Count ?? 0;
    var hasCoords = Model.Latitude.HasValue && Model.Longitude.HasValue;
    var approvedReviews = Model.Reviews?.Where(r => r.Status == ReviewStatus.Approved).OrderByDescending(r => r.CreatedAt).ToList() ?? new List<Review>();
}

<style>
    .tour-hero {
        position: relative;
        height: 60vh;
        min-height: 400px;
        max-height: 600px;
        background: linear-gradient(135deg, var(--primary) 0%, #5ba4e5 100%);
        overflow: hidden;
    }
    .tour-hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        filter: brightness(0.6);
        transition: transform 0.3s ease;
    }
    .tour-hero:hover .tour-hero-bg {
        transform: scale(1.02);
    }
    .tour-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.5) 100%);
    }
    .tour-hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 3rem;
        color: white;
    }
    .tour-hero-content h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        text-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }
    .info-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        padding: 0.4rem 0.9rem;
        border-radius: 50px;
        font-size: 0.85rem;
        color: white;
        margin-right: 0.5rem;
        margin-bottom: 0.5rem;
    }
    .booking-sticky {
        position: sticky;
        top: 80px;
    }
    .booking-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        border: none;
        overflow: hidden;
    }
    .booking-card-header {
        background: linear-gradient(135deg, var(--primary) 0%, #5ba4e5 100%);
        color: white;
        padding: 1.5rem;
        text-align: center;
    }
    .booking-card-body {
        padding: 1.5rem;
    }
    .price-large {
        font-size: 2rem;
        font-weight: 700;
        color: white;
    }
    .section-divider {
        border: none;
        border-top: 1px solid var(--border-color);
        margin: 2rem 0;
    }
    .detail-section {
        margin-bottom: 2rem;
    }
    .detail-section-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .detail-section-title::before {
        content: '';
        width: 4px;
        height: 20px;
        background: var(--primary);
        border-radius: 2px;
    }
    .rating-bar {
        height: 8px;
        background: var(--bg-gray);
        border-radius: 4px;
        overflow: hidden;
        flex-grow: 1;
    }
    .rating-bar-fill {
        height: 100%;
        background: var(--warning);
        border-radius: 4px;
    }
    .review-card {
        background: white;
        border-radius: 12px;
        padding: 1.25rem;
        border: 1px solid var(--border-color);
        margin-bottom: 1rem;
        transition: all 0.2s ease;
    }
    .review-card:hover {
        box-shadow: var(--shadow);
    }
    .cta-button {
        width: 100%;
        padding: 1rem;
        font-size: 1.05rem;
        font-weight: 600;
        border-radius: 12px;
        transition: all 0.3s ease;
    }
    .cta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(74,144,217,0.4);
    }
    .fade-in {
        animation: fadeIn 0.6s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s ease;
    }
    .back-link:hover {
        color: var(--primary);
    }
    .info-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--border-color);
    }
    .info-item:last-child {
        border-bottom: none;
    }
    .info-icon {
        width: 40px;
        height: 40px;
        background: var(--primary-light);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .info-icon svg {
        width: 18px;
        height: 18px;
        stroke: var(--primary);
        fill: none;
        stroke-width: 2;
    }
</style>

<!-- Hero -->
<section class="tour-hero">
    @if (!string.IsNullOrEmpty(Model.PhotoUrl))
    {
        <div class="tour-hero-bg" style="background-image: url('@Model.PhotoUrl')"></div>
    }
    <div class="tour-hero-overlay"></div>
    <div class="tour-hero-content">
        <div class="container">
            <a href="#" class="back-link text-white mb-3 d-inline-block" onclick="history.back(); return false;">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Назад
            </a>
            <h1>@Model.Name</h1>
            <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                <span class="info-chip">
                    <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    @(new string('★', Model.Stars))
                </span>
                <span class="info-chip">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    @Model.City?.Name, @Model.City?.Country?.Name
                </span>
                <span class="info-chip">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 3h18v18H3zM3 9h18M9 21V9"/></svg>
                    @Model.MealType.GetDisplayName()
                </span>
                @if (reviewCount > 0)
                {
                    <span class="info-chip">
                        <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        @avgRating.ToString("0.0")
                    </span>
                }
            </div>
            @if (Model.PricePerNight.HasValue)
            {
                <div class="price-large">
                    @Model.PricePerNight.Value.ToString("N0") ₽
                    <span style="font-size: 1rem; font-weight: 400; opacity: 0.8;">за ночь</span>
                </div>
            }
        </div>
    </div>
</section>

<!-- Контент -->
<div class="container py-5 fade-in">
    <div class="row g-5">

        <!-- Левая колонка -->
        <div class="col-lg-8">

            <!-- Описание -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="detail-section">
                    <h3 class="detail-section-title">Описание</h3>
                    <p style="line-height: 1.9; color: var(--text-dark); font-size: 1.05rem;">@Model.Description</p>
                </div>
                <hr class="section-divider">
            }

            <!-- Информация -->
            <div class="detail-section">
                <h3 class="detail-section-title">Информация об отеле</h3>
                <div class="card tour-card">
                    <div class="card-body p-4">
                        <div class="info-item">
                            <div class="info-icon">
                                <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                            </div>
                            <div>
                                <div class="text-muted small">Категория</div>
                                <div class="fw-semibold text-warning">@(new string('★', Model.Stars))</div>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon">
                                <svg viewBox="0 0 24 24"><path d="M3 3h18v18H3zM3 9h18M9 21V9"/></svg>
                            </div>
                            <div>
                                <div class="text-muted small">Питание</div>
                                <div class="fw-semibold">@Model.MealType.GetDisplayName()</div>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon">
                                <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            </div>
                            <div>
                                <div class="text-muted small">Город</div>
                                <div class="fw-semibold">@Model.City?.Name, @Model.City?.Country?.Name</div>
                            </div>
                        </div>
                        @if (Model.DistanceToBeach.HasValue)
                        {
                            <div class="info-item">
                                <div class="info-icon">
                                    <svg viewBox="0 0 24 24"><path d="M2 20c2-1 4-1 6 0s4 1 6 0 4-1 6 0"/><path d="M12 3v10"/></svg>
                                </div>
                                <div>
                                    <div class="text-muted small">До пляжа</div>
                                    <div class="fw-semibold">@Model.DistanceToBeach м</div>
                                </div>
                            </div>
                        }
                        @if (Model.DistanceToCenter.HasValue)
                        {
                            <div class="info-item">
                                <div class="info-icon">
                                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                                </div>
                                <div>
                                    <div class="text-muted small">До центра</div>
                                    <div class="fw-semibold">@Model.DistanceToCenter км</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <hr class="section-divider">

            <!-- Карта -->
            @if (hasCoords)
            {
                <div class="detail-section">
                    <h3 class="detail-section-title">Расположение</h3>
                    <div class="card tour-card">
                        <div class="card-body p-3">
                            <div id="detailMap" style="height:400px;border-radius:12px;overflow:hidden"></div>
                        </div>
                    </div>
                </div>
                <hr class="section-divider">
            }

            <!-- Сообщения -->
            @if (TempData["ReviewSuccess"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4">@TempData["ReviewSuccess"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @if (TempData["ReviewError"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4">@TempData["ReviewError"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }

            <!-- Отзывы -->
            <div class="detail-section">
                <h3 class="detail-section-title">Отзывы</h3>

                @if (Context.Session.GetInt32("UserId") != null)
                {
                    <div class="card tour-card mb-4">
                        <div class="card-body p-4">
                            <h6 class="mb-3 fw-semibold">Оставить отзыв</h6>
                            <form asp-action="AddReview" asp-controller="Hotels" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="HotelId" value="@Model.Id" />
                                <div class="mb-3">
                                    <div class="star-rating-input">
                                        @for (int i = 5; i >= 1; i--)
                                        {
                                            <input type="radio" name="Rating" value="@i" id="star@(i)" @(i == 5 ? "checked" : "") class="d-none" />
                                            <label for="star@(i)" class="star-label">★</label>
                                        }
                                    </div>
                                </div>
                                <textarea name="Text" class="form-control mb-3" rows="3" placeholder="Поделитесь впечатлениями..." required minlength="10"></textarea>
                                <button type="submit" class="btn btn-primary">Отправить</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card tour-card mb-4">
                        <div class="card-body p-4 text-center">
                            <p class="mb-2 text-muted">Хотите оставить отзыв?</p>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Войдите</a>
                        </div>
                    </div>
                }

                @if (approvedReviews.Any())
                {
                    <!-- Средний рейтинг -->
                    <div class="card tour-card mb-4">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center gap-4">
                                <div class="text-center">
                                    <div style="font-size:3rem;font-weight:700;color:var(--primary);line-height:1">@avgRating.ToString("0.0")</div>
                                    <div class="text-muted small">из 5</div>
                                </div>
                                <div class="flex-grow-1">
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        var count = approvedReviews.Count(r => r.Rating == i);
                                        var pct = approvedReviews.Count > 0 ? (double)count / approvedReviews.Count * 100 : 0;
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <span class="small" style="width:12px;color:var(--warning)">★</span>
                                            <span class="small text-muted" style="width:8px">@i</span>
                                            <div class="rating-bar">
                                                <div class="rating-bar-fill" style="width:@pct%"></div>
                                            </div>
                                            <span class="small text-muted" style="width:24px;text-align:right">@count</span>
                                        </div>
                                    }
                                </div>
                                <div class="text-center">
                                    <div class="text-muted small">@approvedReviews.Count</div>
                                    <div class="text-muted small">отзывов</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (!approvedReviews.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="mb-3" style="opacity:0.3"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                        <p>Отзывов пока нет. Будьте первым!</p>
                    </div>
                }
                else
                {
                    @foreach (var review in approvedReviews)
                    {
                        <div class="review-card">
                            <div class="d-flex gap-3">
                                @if (!string.IsNullOrEmpty(review.User?.AvatarUrl))
                                {
                                    <img src="@review.User.AvatarUrl" class="rounded-circle flex-shrink-0" style="width:44px;height:44px;object-fit:cover" />
                                }
                                else
                                {
                                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;background:linear-gradient(135deg,var(--primary),#5ba4e5);color:white;font-size:.9rem;font-weight:600">
                                        @(review.User?.FullName?.FirstOrDefault() ?? '?')
                                    </div>
                                }
                                <div class="min-width-0 flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <strong style="color:var(--text-dark)">@review.User?.FullName</strong>
                                        <small class="text-muted">@review.CreatedAt.ToString("dd.MM.yyyy")</small>
                                    </div>
                                    <div class="mb-2">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span style="color:@(i <= review.Rating ? "var(--warning)" : "var(--text-light)");font-size:.9rem">★</span>
                                        }
                                    </div>
                                    <p class="mb-0" style="line-height:1.7;">@review.Text</p>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

        </div>

        <!-- Правая колонка — Booking -->
        <div class="col-lg-4">
            <div class="booking-sticky">
                <div class="booking-card mb-4">
                    <div class="booking-card-header">
                        @if (Model.PricePerNight.HasValue)
                        {
                            <div class="price-large">@Model.PricePerNight.Value.ToString("N0") ₽</div>
                            <div style="opacity:0.8;font-size:0.9rem;">за ночь</div>
                        }
                        @if (reviewCount > 0)
                        {
                            <div class="mt-2">
                                <span class="text-warning">★</span>
                                <strong>@avgRating.ToString("0.0")</strong>
                                <span style="opacity:0.8;font-size:0.85rem;">(@reviewCount)</span>
                            </div>
                        }
                    </div>
                    <div class="booking-card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid var(--border-color)">
                                <span class="text-muted small">Категория</span>
                                <span class="fw-semibold small text-warning">@(new string('★', Model.Stars))</span>
                            </div>
                            <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid var(--border-color)">
                                <span class="text-muted small">Питание</span>
                                <span class="fw-semibold small">@Model.MealType.GetDisplayName()</span>
                            </div>
                            <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid var(--border-color)">
                                <span class="text-muted small">Город</span>
                                <span class="fw-semibold small">@Model.City?.Name</span>
                            </div>
                            <div class="d-flex justify-content-between py-2">
                                <span class="text-muted small">Страна</span>
                                <span class="fw-semibold small">@Model.City?.Country?.Name</span>
                            </div>
                        </div>

                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <a asp-controller="Chat" asp-action="Create" asp-route-hotelId="@Model.Id" class="btn btn-primary cta-button mb-2">
                                Задать вопрос
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-primary cta-button">
                                Войдите для связи
                            </a>
                        }
                    </div>
                </div>

                <div class="text-center">
                    <a asp-action="Index" class="back-link">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                        Ко всем отелям
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @if (hasCoords)
    {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            (function() {
                var lat = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Latitude));
                var lng = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Longitude));
                var name = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Name));
                var map = L.map('detailMap').setView([lat, lng], 14);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {attribution:'© OpenStreetMap'}).addTo(map);
                L.marker([lat, lng]).bindPopup('<b>' + name + '</b>').addTo(map);
            })();
        </script>
    }
}
