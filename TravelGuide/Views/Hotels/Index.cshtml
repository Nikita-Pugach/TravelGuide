@model TravelGuide.ViewModels.PaginatedList<TravelGuide.Models.Entities.Hotel>
@using TravelGuide.Models.Entities

@{
    ViewData["Title"] = "Отели";
    var paginationModel = new TravelGuide.ViewModels.PaginationViewModel
    {
        CurrentPage = Model.CurrentPage,
        TotalPages = Model.TotalPages,
        PageSize = Model.PageSize,
        TotalItems = Model.TotalItems,
        Action = "Index",
        Controller = "Hotels",
        RouteValues = new Dictionary<string, string>
        {
            { "search", ViewBag.CurrentSearch ?? "" },
            { "stars", ViewBag.CurrentStars?.ToString() ?? "" },
            { "cityId", ViewBag.CurrentCityId?.ToString() ?? "" },
            { "minPrice", ViewBag.CurrentMinPrice?.ToString() ?? "" },
            { "maxPrice", ViewBag.CurrentMaxPrice?.ToString() ?? "" },
            { "mealType", ViewBag.CurrentMealType?.ToString() ?? "" },
            { "sortBy", ViewBag.CurrentSortBy ?? "" }
        }
    };
}

<div class="hero-section py-5 text-center">
    <div class="container">
        <h1>Отели мира</h1>
        <p class="lead">Найдите идеальное место для проживания</p>
    </div>
</div>

<div class="container mt-4">
    <div class="search-card mb-4">
        <form method="get">
            <div class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="search" class="form-control" placeholder="Поиск отеля..." value="@ViewBag.CurrentSearch">
                </div>
                <div class="col-md-2">
                    <select name="stars" class="form-select">
                        <option value="">Все звёзды</option>
                        @for (int s = 5; s >= 1; s--)
                        {
                            <option value="@s" selected="@(ViewBag.CurrentStars == s)">@s ★</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="cityId" class="form-select">
                        <option value="">Все города</option>
                        @if (ViewBag.Cities != null)
                        {
                            foreach (var c in ViewBag.Cities)
                            {
                                <option value="@c.Id" selected="@(ViewBag.CurrentCityId == c.Id)">@c.Name (@c.Country?.Name)</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="sortBy" class="form-select">
                        <option value="">По названию</option>
                        <option value="price_asc" selected="@(ViewBag.CurrentSortBy == "price_asc")">Цена ↑</option>
                        <option value="price_desc" selected="@(ViewBag.CurrentSortBy == "price_desc")">Цена ↓</option>
                        <option value="stars_desc" selected="@(ViewBag.CurrentSortBy == "stars_desc")">Звёзды ↓</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary w-100">Найти</button>
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-outline-secondary w-100" data-bs-toggle="collapse" data-bs-target="#advancedSearch">Фильтры</button>
                </div>
            </div>
            <div class="collapse mt-3" id="advancedSearch">
                <div class="row g-3 pt-3 border-top">
                    <div class="col-md-3">
                        <label class="form-label">Цена за ночь от</label>
                        <input type="number" name="minPrice" class="form-control" placeholder="Мин. цена ₽" value="@ViewBag.CurrentMinPrice">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Цена за ночь до</label>
                        <input type="number" name="maxPrice" class="form-control" placeholder="Макс. цена ₽" value="@ViewBag.CurrentMaxPrice">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Тип питания</label>
                        <select name="mealType" class="form-select">
                            <option value="">Любой</option>
                            @if (ViewBag.MealTypes != null)
                            {
                                foreach (MealType m in ViewBag.MealTypes)
                                {
                                    <option value="@((int)m)" selected="@(ViewBag.CurrentMealType == (int)m)">@m.GetDisplayName()</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>
        </form>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var hotel in Model)
            {
                var avgRating = hotel.Reviews != null && hotel.Reviews.Any() 
                    ? hotel.Reviews.Average(r => r.Rating) 
                    : 0;
                var reviewCount = hotel.Reviews?.Count ?? 0;
                
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 tour-card border-0">
                        @if (!string.IsNullOrEmpty(hotel.PhotoUrl))
                        {
                            <img src="@hotel.PhotoUrl" class="card-img-top" alt="@hotel.Name" style="height: 200px; object-fit: cover; border-radius: 12px 12px 0 0;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px; border-radius: 12px 12px 0 0;">
                                <span style="font-size: 3rem;">🏨</span>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title text-truncate">@hotel.Name</h5>
                            <p class="text-muted small mb-2">
                                @if (hotel.City != null)
                                {
                                    <span>@hotel.City.Name, @hotel.City.Country?.Name</span>
                                }
                            </p>
                            <div class="d-flex align-items-center mb-2">
                                <span class="text-warning me-2">@(new string('★', hotel.Stars))</span>
                                @if (reviewCount > 0)
                                {
                                    <span class="star-rating">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= Math.Round(avgRating))
                                            {
                                                <span>★</span>
                                            }
                                            else
                                            {
                                                <span class="empty">★</span>
                                            }
                                        }
                                    </span>
                                    <span class="text-muted small ms-2">(@reviewCount)</span>
                                }
                            </div>
                            <p class="card-text text-truncate text-muted small">@hotel.Description</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="price-tag">@(hotel.PricePerNight?.ToString("N0") ?? "Договорная") ₽<small>/ночь</small></span>
                                <span class="badge bg-light text-dark">@hotel.MealType.GetDisplayName()</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pt-0">
                            <a asp-action="Details" asp-route-id="@hotel.Id" class="btn btn-outline-primary w-100">
                                Подробнее
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
        
        @if (Model.TotalPages > 1)
        {
            <partial name="_Pagination" model="paginationModel" />
        }
    }
    else
    {
        <div class="text-center py-5">
            <h3>Отели не найдены</h3>
            <p class="text-muted">Попробуйте изменить параметры поиска</p>
            <a asp-action="Index" class="btn btn-primary">Показать все отели</a>
        </div>
    }
</div>