@model TravelGuide.ViewModels.BookingCreateViewModel

@{
    ViewData["Title"] = "Бронирование тура";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card tour-card">
                <div class="card-body p-4">
                    <h4 class="mb-4" style="font-weight: 600;">Заявка на бронирование тура</h4>
                    
                    <!-- Информация о туре -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            @if (!string.IsNullOrEmpty(Model.TourPhotoUrl))
                            {
                                <img src="@Model.TourPhotoUrl" class="img-fluid rounded" alt="@Model.TourName" style="height: 150px; object-fit: cover; width: 100%;">
                            }
                            else
                            {
                                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 150px; border: 1px solid #dee2e6;">
                                    <span class="text-muted">Нет фото</span>
                                </div>
                            }
                        </div>
                        <div class="col-md-8">
                            <h5 style="font-weight: 600;">@Model.TourName</h5>
                            <p class="text-muted mb-2">@Model.CountryName</p>
                            <p class="mb-1 text-muted">Продолжительность: <strong>@Model.Duration дн.</strong></p>
                            <p class="mb-0 text-muted">Цена за человека: <strong style="color: var(--primary);">@Model.TourPrice.ToString("N0") &#8381;</strong></p>
                        </div>
                    </div>

                    <hr style="border-color: var(--border-color);">

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="TourId" />
                        <input type="hidden" asp-for="TourName" />
                        <input type="hidden" asp-for="TourPrice" />
                        <input type="hidden" asp-for="Duration" />
                        <input type="hidden" asp-for="TourPhotoUrl" />
                        <input type="hidden" asp-for="CountryName" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="BookingDate" class="form-label"></label>
                                <input asp-for="BookingDate" class="form-control" type="date" 
                                       min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="BookingDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="GuestsCount" class="form-label"></label>
                                <input asp-for="GuestsCount" class="form-control" type="number" min="1" max="100" 
                                       id="guestsCount" />
                                <span asp-validation-for="GuestsCount" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label"></label>
                                <input asp-for="Phone" class="form-control" placeholder="+375 (29) 123-45-67" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3" 
                                      placeholder="Пожелания, вопросы, особые требования..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <div class="card mb-3" style="background: var(--bg-light); border: 1px solid var(--border-color);">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Итого к оплате:</span>
                                    <h4 class="mb-0" style="color: var(--primary); font-weight: 600;" id="totalPrice">@Model.TotalPrice.ToString("N0") &#8381;</h4>
                                </div>
                                <small class="text-muted">@Model.TourPrice.ToString("N0") &#8381; × <span id="guestsDisplay">@Model.GuestsCount</span> чел.</small>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a asp-controller="Tours" asp-action="Details" asp-route-id="@Model.TourId" 
                               class="btn btn-outline-secondary">Назад к туру</a>
                            <button type="submit" class="btn btn-primary flex-fill">Отправить заявку</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        const pricePerPerson = @Model.TourPrice;
        const guestsInput = document.getElementById('guestsCount');
        const totalPriceEl = document.getElementById('totalPrice');
        const guestsDisplayEl = document.getElementById('guestsDisplay');

        guestsInput.addEventListener('input', function() {
            const guests = parseInt(this.value) || 1;
            const total = pricePerPerson * guests;
            totalPriceEl.textContent = total.toLocaleString('ru-RU') + ' ₽';
            guestsDisplayEl.textContent = guests;
        });
    </script>
}