@model IEnumerable<TravelGuide.Models.Entities.Chat>
@{
    ViewData["Title"] = "Чаты с клиентами";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Чаты с клиентами</h2>
    </div>
    
    <!-- Фильтры -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        <a asp-action="Chats" class="btn @(ViewBag.Status == null ? "btn-primary" : "btn-outline-primary")">Все</a>
        <a asp-action="Chats" asp-route-status="Active" class="btn @(ViewBag.Status?.ToString() == "Active" ? "btn-success" : "btn-outline-success")">Активные</a>
        <a asp-action="Chats" asp-route-status="Closed" class="btn @(ViewBag.Status?.ToString() == "Closed" ? "btn-secondary" : "btn-outline-secondary")">Закрытые</a>
    </div>
    
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted">Чатов пока нет</p>
        </div>
    }
    else
    {
        <div class="card shadow">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Пользователь</th>
                                <th>Статус</th>
                                <th>Начало</th>
                                <th>Последнее сообщение</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var chat in Model)
                            {
                                var lastMessage = chat.Messages?.OrderByDescending(m => m.Timestamp).FirstOrDefault();
                                
                                <tr>
                                    <td><strong>#@chat.Id</strong></td>
                                    <td>
                                        @if (chat.User != null)
                                        {
                                            <span>@chat.User.FullName</span>
                                            <br />
                                            <small class="text-muted">@chat.User.Email</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Пользователь удалён</span>
                                        }
                                    </td>
                                    <td>
                                        @if (chat.Status == TravelGuide.Models.Entities.ChatStatus.Active)
                                        {
                                            <span class="badge bg-success">Активен</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Закрыт</span>
                                        }
                                    </td>
                                    <td>@chat.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        @if (lastMessage != null)
                                        {
                                            <span class="text-truncate d-inline-block" style="max-width: 200px;" title="@lastMessage.Text">
                                                @lastMessage.Text
                                            </span>
                                            <br />
                                            <small class="text-muted">@lastMessage.Timestamp.ToString("dd.MM HH:mm")</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Нет сообщений</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="Chat" asp-route-id="@chat.Id" class="btn btn-sm btn-outline-primary">Открыть</a>
                                        @if (chat.Status == TravelGuide.Models.Entities.ChatStatus.Active)
                                        {
                                            <form asp-action="CloseChat" asp-route-id="@chat.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-warning">Закрыть</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>