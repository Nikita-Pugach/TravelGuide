@model IEnumerable<TravelGuide.Models.Entities.Chat>
@using TravelGuide.Models.Entities
@{
    ViewData["Title"] = "Чаты с клиентами";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Чаты с клиентами</h2>
    </div>
    
    <!-- Фильтры -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        <a asp-action="Chats" class="btn @(ViewBag.Status == null ? "btn-primary" : "btn-outline-primary")">Все</a>
        <a asp-action="Chats" asp-route-status="Active" class="btn @(ViewBag.Status?.ToString() == "Active" ? "btn-success" : "btn-outline-success")">Активные</a>
        <a asp-action="Chats" asp-route-status="Closed" class="btn @(ViewBag.Status?.ToString() == "Closed" ? "btn-secondary" : "btn-outline-secondary")">Закрытые</a>
    </div>
    
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted">Чатов пока нет</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var chat in Model)
            {
                var lastMessage = chat.Messages?.OrderByDescending(m => m.Timestamp).FirstOrDefault();
                var userInitials = chat.User?.FullName != null && chat.User.FullName.Length >= 2
                    ? chat.User.FullName.Substring(0, 2).ToUpper()
                    : "?";

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 tour-card border-0">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="avatar-circle me-3" style="width: 44px; height: 44px;">
                                    <span class="avatar-initials" style="font-size: 0.8rem;">@userInitials</span>
                                </div>
                                <div class="flex-grow-1 min-width-0">
                                    <h6 class="mb-0 text-truncate">@(chat.User?.FullName ?? "Пользователь удалён")</h6>
                                    <small class="text-muted">Чат #@chat.Id</small>
                                </div>
                                @if (chat.Status == ChatStatus.Active)
                                {
                                    <span class="badge bg-success">Активен</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Закрыт</span>
                                }
                            </div>
                            
                            <div class="text-muted small mb-2">
                                <div>Начало: @chat.StartTime.ToString("dd.MM.yyyy HH:mm")</div>
                            </div>
                            
                            @if (lastMessage != null)
                            {
                                <div class="p-2 rounded mb-2" style="background: var(--bg-light);">
                                    <div class="small text-truncate" style="max-width: 100%;" title="@lastMessage.Text">
                                        @lastMessage.Text
                                    </div>
                                    <div class="text-muted" style="font-size: 0.7rem;">@lastMessage.Timestamp.ToString("dd.MM HH:mm")</div>
                                </div>
                            }
                            else
                            {
                                <div class="text-muted small text-center py-2">Нет сообщений</div>
                            }
                        </div>
                        <div class="card-footer bg-white border-0 pt-0">
                            <div class="d-flex gap-2">
                                <a asp-action="Chat" asp-route-id="@chat.Id" class="btn btn-outline-primary btn-sm flex-grow-1">Открыть</a>
                                @if (chat.Status == ChatStatus.Active)
                                {
                                    <form asp-action="CloseChat" asp-route-id="@chat.Id" method="post" class="flex-grow-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-warning btn-sm w-100">Закрыть</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>