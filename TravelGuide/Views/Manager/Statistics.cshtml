@model IEnumerable<TravelGuide.Controllers.TourStatistics>
@{
    ViewData["Title"] = "Статистика туров";
}

<!-- Hero Section -->
<section class="hero-section text-center">
    <div class="container position-relative">
        <h1>Статистика туров</h1>
        <p class="lead">Просмотры, отзывы и рейтинг</p>
    </div>
</section>

<div class="container">
    @if (Model.Any())
    {
        <div class="search-card mt-4 mb-4">
            <div class="row text-center g-4">
                <div class="col-md-3">
                    <div class="fw-bold" style="font-size:2rem;color:var(--primary)">@Model.Count()</div>
                    <div class="text-muted small">Всего туров</div>
                </div>
                <div class="col-md-3" style="border-left:1px solid var(--border-color)">
                    <div class="fw-bold" style="font-size:2rem;color:var(--primary)">@Model.Sum(s => s.ViewsCount)</div>
                    <div class="text-muted small">Просмотров</div>
                </div>
                <div class="col-md-3" style="border-left:1px solid var(--border-color)">
                    <div class="fw-bold" style="font-size:2rem;color:var(--primary)">@Model.Sum(s => s.ReviewsCount)</div>
                    <div class="text-muted small">Отзывов</div>
                </div>
                <div class="col-md-3" style="border-left:1px solid var(--border-color)">
                    <div class="fw-bold" style="font-size:2rem;color:var(--primary)">@Model.Average(s => s.AverageRating).ToString("0.0")</div>
                    <div class="text-muted small">Средний рейтинг</div>
                </div>
            </div>
        </div>

        <div class="card tour-card mb-5">
            <div class="card-header">
                <h5 class="mb-0">По турам</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Тур</th>
                                <th class="text-center">Просмотры</th>
                                <th class="text-center">Отзывы</th>
                                <th class="text-center">Рейтинг</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var stat in Model)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Tours" asp-action="Details" asp-route-id="@stat.TourId" class="text-decoration-none fw-semibold" style="color:var(--text-dark)">
                                            @stat.TourName
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <span class="price-tag" style="font-size:0.85rem;">@stat.ViewsCount</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="duration-badge">@stat.ReviewsCount</span>
                                    </td>
                                    <td class="text-center">
                                        @if (stat.AverageRating > 0)
                                        {
                                            <span class="star-rating">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <span class="@(i <= Math.Round(stat.AverageRating) ? "" : "empty")">★</span>
                                                }
                                            </span>
                                            <span class="text-muted small ms-1">@stat.AverageRating.ToString("0.0")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Нет оценок</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <p class="mb-3">Статистика пока пуста</p>
            <a asp-action="Tours" class="btn btn-primary">Управление турами</a>
        </div>
    }
</div>
