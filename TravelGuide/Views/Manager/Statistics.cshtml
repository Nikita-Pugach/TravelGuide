@model IEnumerable<TravelGuide.Controllers.TourStatistics>
@{
    ViewData["Title"] = "Статистика туров";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Статистика туров</h2>
        <a asp-action="Index" class="btn btn-secondary">Назад</a>
    </div>
    
    @if (Model.Any())
    {
        <!-- Статистика -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-3">
                        <div class="price-tag mb-1" style="font-size: 1.25rem;">@Model.Count()</div>
                        <p class="text-muted mb-0 small">Всего туров</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-3">
                        <div class="price-tag mb-1" style="font-size: 1.25rem;">@Model.Sum(s => s.ViewsCount)</div>
                        <p class="text-muted mb-0 small">Просмотров</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-3">
                        <div class="price-tag mb-1" style="font-size: 1.25rem;">@Model.Sum(s => s.ReviewsCount)</div>
                        <p class="text-muted mb-0 small">Отзывов</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-3">
                        <div class="price-tag mb-1" style="font-size: 1.25rem;">@Model.Average(s => s.AverageRating).ToString("0.0")</div>
                        <p class="text-muted mb-0 small">Средний рейтинг</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Таблица -->
        <div class="card shadow">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Тур</th>
                                <th class="text-center">Просмотры</th>
                                <th class="text-center">Отзывы</th>
                                <th class="text-center">Рейтинг</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var stat in Model)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Tours" asp-action="Details" asp-route-id="@stat.TourId" class="text-decoration-none fw-semibold" style="color:var(--text-dark)">
                                            @stat.TourName
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <span class="price-tag" style="font-size:0.85rem;">@stat.ViewsCount</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="duration-badge">@stat.ReviewsCount</span>
                                    </td>
                                    <td class="text-center">
                                        @if (stat.AverageRating > 0)
                                        {
                                            <span class="star-rating">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <span class="@(i <= Math.Round(stat.AverageRating) ? "" : "empty")">★</span>
                                                }
                                            </span>
                                            <span class="text-muted small ms-1">@stat.AverageRating.ToString("0.0")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Нет оценок</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <p class="text-muted">Статистика пока пуста</p>
            <a asp-action="Tours" class="btn btn-primary">Управление турами</a>
        </div>
    }
</div>