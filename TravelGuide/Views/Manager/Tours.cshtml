@model IEnumerable<TravelGuide.Models.Entities.Tour>
@{
    ViewData["Title"] = "Управление турами";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🗺️ Управление турами</h2>
    <a asp-action="CreateTour" class="btn btn-primary">➕ Добавить тур</a>
</div>

<!-- Поиск -->
<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Поиск по названию или описанию..." />
        <button type="submit" class="btn btn-outline-primary">🔍 Найти</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search))
        {
            <a asp-action="Tours" class="btn btn-outline-secondary">Сбросить</a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        <h5>Туры не найдены</h5>
        <p>Добавьте первый тур для начала работы.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Фото</th>
                    <th>Название</th>
                    <th>Тип</th>
                    <th>Длительность</th>
                    <th>Цена</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tour in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(tour.PhotoUrl))
                            {
                                <img src="@tour.PhotoUrl" alt="@tour.Name" class="rounded" style="width: 60px; height: 40px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="width: 60px; height: 40px;">
                                    <span class="text-white small">📷</span>
                                </div>
                            }
                        </td>
                        <td>
                            <strong>@tour.Name</strong>
                            <br />
                            <small class="text-muted">
                                @if (tour.Country != null)
                                {
                                    @tour.Country.Name
                                }
                            </small>
                        </td>
                        <td>
                            <span class="badge bg-info">@tour.TourType</span>
                        </td>
                        <td>@tour.Duration дн.</td>
                        <td><strong>@tour.Price.ToString("N0")</strong> ₽</td>
                        <td>
                            @if (tour.StartDate.HasValue && tour.StartDate > DateTime.Now)
                            {
                                <span class="badge bg-success">Активен</span>
                            }
                            else if (tour.IsSeasonal)
                            {
                                <span class="badge bg-warning text-dark">Сезонный</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Обычный</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-controller="Tours" asp-action="Details" asp-route-id="@tour.Id" class="btn btn-outline-info" title="Просмотр">
                                    👁️
                                </a>
                                <a asp-action="EditTour" asp-route-id="@tour.Id" class="btn btn-outline-primary" title="Редактировать">
                                    ✏️
                                </a>
                                <form asp-action="DeleteTour" asp-route-id="@tour.Id" method="post" style="display: inline;" 
                                      onsubmit="return confirm('Вы уверены, что хотите удалить этот тур?');">
                                    <button type="submit" class="btn btn-outline-danger" title="Удалить">🗑️</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Пагинация -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Tours" asp-route-page="1" asp-route-search="@ViewBag.Search">«</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" asp-action="Tours" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-search="@ViewBag.Search">‹</a>
                    </li>
                }

                @for (int i = Math.Max(1, ViewBag.CurrentPage - 2); i <= Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2); i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Tours" asp-route-page="@i" asp-route-search="@ViewBag.Search">@i</a>
                    </li>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Tours" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-search="@ViewBag.Search">›</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" asp-action="Tours" asp-route-page="@ViewBag.TotalPages" asp-route-search="@ViewBag.Search">»</a>
                    </li>
                }
            </ul>
        </nav>
    }
}