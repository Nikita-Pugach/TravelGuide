@{
    ViewData["Title"] = "Панель менеджера";
}

<div class="container">
    <h2 class="mb-4">Панель менеджера</h2>
    
    <!-- Статистика -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <a asp-action="Tours" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center">
                        <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.ToursCount</div>
                        <p class="text-muted mb-0">Туров</p>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col-md-3">
            <a asp-action="Chats" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center">
                        <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.ActiveChatsCount</div>
                        <p class="text-muted mb-0">Активных чатов</p>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col-md-3">
            <a asp-action="Statistics" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center">
                        <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.TotalViewsCount</div>
                        <p class="text-muted mb-0">Просмотров</p>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col-md-3">
            <a asp-action="Statistics" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center">
                        <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.TotalReviewsCount</div>
                        <p class="text-muted mb-0">Отзывов</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
    
    <!-- Быстрые ссылки -->
    <div class="row g-3">
        <div class="col-md-4">
            <a asp-action="Tours" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-4">
                        <h5 class="mb-1">Туры</h5>
                        <small class="text-muted">Просмотр и управление</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-action="CreateTour" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-4">
                        <h5 class="mb-1">Добавить тур</h5>
                        <small class="text-muted">Создать новое предложение</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-action="Statistics" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-4">
                        <h5 class="mb-1">Статистика</h5>
                        <small class="text-muted">Просмотры, отзывы и рейтинг</small>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
