@{
    ViewData["Title"] = "Панель менеджера";
}

<!-- Hero Section -->
<section class="hero-section text-center">
    <div class="container position-relative">
        <h1>Панель менеджера</h1>
        <p class="lead">Управление турами и чатами</p>
    </div>
</section>

<div class="container">
    <!-- Статистика -->
    <div class="search-card mt-4 mb-4">
            <div class="row text-center g-4">
            <div class="col-md-4">
                <div class="fw-bold" style="font-size:2rem;color:var(--primary)">@ViewBag.ToursCount</div>
                <div class="text-muted small">Туров</div>
                <a asp-action="Tours" class="btn btn-outline-primary btn-sm mt-2">Управление</a>
            </div>
            <div class="col-md-4" style="border-left:1px solid var(--border-color)">
                <div class="fw-bold" style="font-size:2rem;color:var(--primary)">@ViewBag.ActiveChatsCount</div>
                <div class="text-muted small">Активных чатов</div>
                <a asp-action="Chats" class="btn btn-outline-primary btn-sm mt-2">Открыть</a>
            </div>
            <div class="col-md-4" style="border-left:1px solid var(--border-color)">
                <div class="fw-bold" style="font-size:2rem;color:var(--primary)">@ViewBag.TotalReviewsCount</div>
                <div class="text-muted small">Отзывов</div>
                <a asp-action="Statistics" class="btn btn-outline-primary btn-sm mt-2">Статистика</a>
            </div>
        </div>
    </div>

    <!-- Быстрые действия -->
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card tour-card h-100">
                <div class="card-header">
                    <h5 class="mb-0">Быстрые действия</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-action="CreateTour" class="btn btn-primary">Добавить тур</a>
                        <a asp-action="Tours" class="btn btn-outline-primary">Управление турами</a>
                        <a asp-action="Chats" class="btn btn-outline-primary">
                            Чаты с клиентами
                            @if (ViewBag.ActiveChatsCount > 0)
                            {
                                <span class="badge bg-primary ms-1">@ViewBag.ActiveChatsCount</span>
                            }
                        </a>
                        <a asp-action="Statistics" class="btn btn-outline-secondary">Статистика</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card tour-card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Активные чаты</h5>
                    <a asp-action="Chats" class="btn btn-sm btn-outline-primary">Все чаты</a>
                </div>
                <div class="card-body">
                    @if (ViewBag.ActiveChats != null && ViewBag.ActiveChats.Count > 0)
                    {
                        @foreach (var chat in ViewBag.ActiveChats)
                        {
                            <a asp-action="Chat" asp-route-id="@chat.Id" class="d-flex justify-content-between align-items-center p-2 mb-2 rounded text-decoration-none" style="background:var(--bg-light);color:var(--text-dark);transition:all 0.2s" onmouseover="this.style.background='var(--primary-light)'" onmouseout="this.style.background='var(--bg-light)'">
                                <span class="fw-semibold small">Чат #@chat.Id</span>
                                <small class="text-muted">@chat.StartTime.ToString("dd.MM HH:mm")</small>
                            </a>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center mb-0 py-3">Нет активных чатов</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
