@{
    ViewData["Title"] = "Панель менеджера";
}

<div class="container">
    <h2 class="mb-4">Панель менеджера</h2>
    
    <!-- Статистика -->
    <div class="row g-3 mb-5">
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.ToursCount</div>
                    <p class="text-muted mb-0">Туров</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pt-0">
                    <a asp-action="Tours" class="btn btn-outline-primary btn-sm w-100">Управление</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.ActiveChatsCount</div>
                    <p class="text-muted mb-0">Активных чатов</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pt-0">
                    <a asp-action="Chats" class="btn btn-outline-primary btn-sm w-100">Чаты</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.PendingReviewsCount</div>
                    <p class="text-muted mb-0">На модерации</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pt-0">
                    <a asp-action="Statistics" class="btn btn-outline-primary btn-sm w-100">Статистика</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card tour-card h-100">
                <div class="card-body text-center">
                    <div class="price-tag mb-2" style="font-size: 1.5rem;">@ViewBag.TotalReviewsCount</div>
                    <p class="text-muted mb-0">Отзывов</p>
                </div>
                <div class="card-footer bg-white border-0 text-center pt-0">
                    <a asp-action="Statistics" class="btn btn-outline-primary btn-sm w-100">Статистика</a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Разделы -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card tour-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Управление</h5>
                    <div class="d-grid gap-2">
                        <a asp-action="Tours" class="btn btn-outline-primary">Туры</a>
                        <a asp-action="CreateTour" class="btn btn-outline-primary">Добавить тур</a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card tour-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Чаты</h5>
                    <div class="d-grid gap-2">
                        <a asp-action="Chats" class="btn btn-outline-primary">
                            Чаты с клиентами
                            @if (ViewBag.ActiveChatsCount > 0)
                            {
                                <span class="badge bg-primary ms-1">@ViewBag.ActiveChatsCount</span>
                            }
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card tour-card h-100">
                <div class="card-body">
                    <h5 class="card-title">Статистика</h5>
                    <p class="text-muted small">Просмотры, отзывы и рейтинг туров</p>
                    <div class="d-grid gap-2">
                        <a asp-action="Statistics" class="btn btn-primary">Открыть статистику</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>