@{
    ViewData["Title"] = "Панель менеджера";
}

<div class="container">
    <h2 class="mb-4" style="font-weight: 600;">Панель менеджера</h2>
    
    <!-- Статистика -->
    <div class="row g-3 mb-5">
        <div class="col">
            <a asp-action="Tours" class="text-decoration-none">
                <div class="card h-100" style="border-left: 4px solid #198754;">
                    <div class="card-body text-center py-3">
                        <div style="font-weight: 700; color: #198754; font-size: 1.8rem;">@ViewBag.ToursCount</div>
                        <div class="text-muted small">Туров</div>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col">
            <a asp-action="Chats" class="text-decoration-none">
                <div class="card h-100" style="border-left: 4px solid #dc3545;">
                    <div class="card-body text-center py-3">
                        <div style="font-weight: 700; color: #dc3545; font-size: 1.8rem;">@ViewBag.ActiveChatsCount</div>
                        <div class="text-muted small">Активных чатов</div>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col">
            <a asp-action="Statistics" class="text-decoration-none">
                <div class="card h-100" style="border-left: 4px solid #ffc107;">
                    <div class="card-body text-center py-3">
                        <div style="font-weight: 700; color: #ffc107; font-size: 1.8rem;">@ViewBag.PendingReviewsCount</div>
                        <div class="text-muted small">На модерации</div>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col">
            <a asp-action="Statistics" class="text-decoration-none">
                <div class="card h-100" style="border-left: 4px solid var(--primary);">
                    <div class="card-body text-center py-3">
                        <div style="font-weight: 700; color: var(--primary); font-size: 1.8rem;">@ViewBag.TotalReviewsCount</div>
                        <div class="text-muted small">Отзывов</div>
                    </div>
                </div>
            </a>
        </div>
    </div>
    
    <!-- Разделы -->
    <div class="card" style="border-top: 3px solid var(--primary);">
        <div class="card-body">
            <div class="row">
                <div class="col-md-7">
                    <h5 class="card-title" style="font-weight: 600;">Управление</h5>
                    <div class="list-group list-group-flush">
                        <a asp-action="Tours" class="list-group-item list-group-item-action">Туры</a>
                        <a asp-action="CreateTour" class="list-group-item list-group-item-action">Добавить тур</a>
                        <a asp-action="Chats" class="list-group-item list-group-item-action">
                            Чаты с клиентами
                            @if (ViewBag.ActiveChatsCount > 0)
                            {
                                <span class="badge bg-primary float-end">@ViewBag.ActiveChatsCount</span>
                            }
                        </a>
                    </div>
                </div>
                <div class="col-md-5">
                    <h5 class="card-title" style="font-weight: 600;">Статистика</h5>
                    <p class="text-muted small">Просмотры, отзывы и рейтинг туров</p>
                    <a asp-action="Statistics" class="btn btn-outline-primary">Открыть статистику</a>
                </div>
            </div>
        </div>
    </div>
</div>
