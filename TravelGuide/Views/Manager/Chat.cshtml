@model TravelGuide.Models.Entities.Chat
@{
    ViewData["Title"] = $"Чат #{Model.Id}";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">💬 Чат #@Model.Id</h5>
        <div>
            @if (Model.Status == TravelGuide.Models.Entities.ChatStatus.Active)
            {
                <span class="badge bg-success">🟢 Активен</span>
                <form asp-action="CloseChat" asp-route-id="@Model.Id" method="post" style="display: inline;">
                    <button type="submit" class="btn btn-sm btn-warning">Закрыть чат</button>
                </form>
            }
            else
            {
                <span class="badge bg-secondary">Закрыт</span>
            }
        </div>
    </div>
    
    <div class="card-body">
        <!-- Информация о пользователе -->
        <div class="mb-3 p-2 bg-light rounded">
            <strong>Пользователь:</strong>
            @if (Model.User != null)
            {
                <span>@Model.User.FullName (@Model.User.Email)</span>
            }
            <br />
            <small class="text-muted">Начало: @Model.StartTime.ToString("dd.MM.yyyy HH:mm")</small>
        </div>
        
        <!-- Сообщения -->
        <div id="chatMessages" class="border rounded p-3 mb-3" style="height: 400px; overflow-y: auto; background-color: #f8f9fa;">
            @if (Model.Messages != null && Model.Messages.Any())
            {
                @foreach (var message in Model.Messages.OrderBy(m => m.Timestamp))
                {
                    var isManager = message.SenderId != Model.UserId;
                    <div class="mb-2 @(isManager ? "text-end" : "")">
                        <div class="d-inline-block p-2 rounded @(isManager ? "bg-primary text-white" : "bg-white")" style="max-width: 70%;">
                            <div class="small text-muted mb-1">
                                @(isManager ? "Менеджер" : Model.User?.FullName ?? "Пользователь")
                                <span class="ms-2">@message.Timestamp.ToString("HH:mm")</span>
                            </div>
                            <div>@message.Text</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-center text-muted">Нет сообщений</p>
            }
        </div>
        
        <!-- Форма отправки -->
        @if (Model.Status == TravelGuide.Models.Entities.ChatStatus.Active)
        {
            <form id="sendMessageForm" class="d-flex gap-2">
                <input type="hidden" id="chatId" value="@Model.Id" />
                <input type="text" id="messageInput" class="form-control" placeholder="Введите сообщение..." required />
                <button type="submit" class="btn btn-primary">📤 Отправить</button>
            </form>
        }
        else
        {
            <div class="alert alert-warning mb-0">
                ⚠️ Чат закрыт. Отправка сообщений недоступна.
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Chats" class="btn btn-outline-secondary">← Назад к списку чатов</a>
</div>

@section Scripts {
    <script>
        // Прокрутка вниз при загрузке
        var chatMessages = document.getElementById('chatMessages');
        chatMessages.scrollTop = chatMessages.scrollHeight;
        
        // Отправка через форму (fallback без SignalR)
        document.getElementById('sendMessageForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            const messageInput = document.getElementById('messageInput');
            const chatId = document.getElementById('chatId').value;
            const message = messageInput.value.trim();
            
            if (!message) return;
            
            try {
                const response = await fetch('/Chat/SendMessage', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `chatId=${chatId}&text=${encodeURIComponent(message)}`
                });
                
                if (response.ok) {
                    // Добавляем сообщение в чат
                    const messageDiv = document.createElement('div');
                    messageDiv.className = 'mb-2 text-end';
                    messageDiv.innerHTML = `
                        <div class="d-inline-block p-2 rounded bg-primary text-white" style="max-width: 70%;">
                            <div class="small text-muted mb-1">Менеджер <span class="ms-2">${new Date().toLocaleTimeString('ru-RU', {hour: '2-digit', minute: '2-digit'})}</span></div>
                            <div>${message}</div>
                        </div>
                    `;
                    chatMessages.appendChild(messageDiv);
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                    messageInput.value = '';
                }
            } catch (error) {
                console.error('Error:', error);
            }
        });
    </script>
}