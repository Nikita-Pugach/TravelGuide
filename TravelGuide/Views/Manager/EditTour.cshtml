@model TravelGuide.Models.Entities.Tour
@{
    ViewData["Title"] = "Редактирование тура";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card">
            <div class="card-header">
                <h4>✏️ Редактирование тура</h4>
            </div>
            <div class="card-body">
                <form asp-action="EditTour" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label asp-for="Name" class="form-label">Название тура *</label>
                                <input asp-for="Name" class="form-control" required />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label asp-for="TourType" class="form-label">Тип тура</label>
                                <select asp-for="TourType" class="form-select" asp-items="Html.GetEnumSelectList<TravelGuide.Models.Entities.TourType>()"></select>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Описание</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="CountryId" class="form-label">Страна *</label>
                                <select asp-for="CountryId" class="form-select" required>
                                    <option value="">-- Выберите страну --</option>
                                    @foreach (var country in ViewBag.Countries)
                                    {
                                        <option value="@country.Id" selected="@(Model.CountryId == country.Id)">@country.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="AgencyId" class="form-label">Агентство</label>
                                <select asp-for="AgencyId" class="form-select">
                                    <option value="">-- Выберите агентство --</option>
                                    @foreach (var agency in ViewBag.Agencies)
                                    {
                                        <option value="@agency.Id" selected="@(Model.AgencyId == agency.Id)">@agency.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Duration" class="form-label">Продолжительность (дней) *</label>
                                <input asp-for="Duration" class="form-control" type="number" min="1" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Price" class="form-label">Цена (₽) *</label>
                                <input asp-for="Price" class="form-control" type="number" min="0" step="0.01" required />
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="StartDate" class="form-label">Дата начала</label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="EndDate" class="form-label">Дата окончания</label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="IsSeasonal" class="form-check-input" />
                            <label asp-for="IsSeasonal" class="form-check-label">Сезонный тур</label>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Route" class="form-label">Маршрут по дням</label>
                        <textarea asp-for="Route" class="form-control" rows="4" placeholder="День 1: ...&#10;День 2: ...&#10;и т.д."></textarea>
                    </div>
                    
                    <!-- Отели -->
                    <div class="mb-3">
                        <label class="form-label">Отели в туре</label>
                        <div class="row">
                            @foreach (var hotel in ViewBag.Hotels)
                            {
                                <div class="col-md-4 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="selectedHotels" value="@hotel.Id" 
                                               id="hotel_@hotel.Id" checked="@(ViewBag.SelectedHotels != null && ((List<int>)ViewBag.SelectedHotels).Contains(hotel.Id))" />
                                        <label class="form-check-label" for="hotel_@hotel.Id">
                                            @hotel.Name <small class="text-muted">(@hotel.Stars ★)</small>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    
                    <!-- Достопримечательности -->
                    <div class="mb-3">
                        <label class="form-label">Достопримечательности</label>
                        <div class="row">
                            @foreach (var sight in ViewBag.Sights)
                            {
                                <div class="col-md-4 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="selectedSights" value="@sight.Id" 
                                               id="sight_@sight.Id" checked="@(ViewBag.SelectedSights != null && ((List<int>)ViewBag.SelectedSights).Contains(sight.Id))" />
                                        <label class="form-check-label" for="sight_@sight.Id">
                                            @sight.Name
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    
                    <!-- Изображение -->
                    @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                    {
                        <div class="mb-3">
                            <label class="form-label">Текущее фото</label>
                            <div>
                                <img src="@Model.PhotoUrl" alt="Tour photo" class="img-thumbnail" style="width: 150px; height: 100px; object-fit: cover;" />
                            </div>
                            <div class="form-check mt-2">
                                <input type="checkbox" name="removeImages" value="true" class="form-check-input" id="removeImages" />
                                <label class="form-check-label text-danger" for="removeImages">Удалить фото</label>
                            </div>
                        </div>
                    }
                    
                    <div class="mb-3">
                        <label for="images" class="form-label">Загрузить фото</label>
                        <input type="file" name="images" id="images" class="form-control" accept="image/*" />
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">💾 Сохранить</button>
                        <a asp-action="Tours" class="btn btn-outline-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>