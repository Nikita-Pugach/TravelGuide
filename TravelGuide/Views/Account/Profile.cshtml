@model TravelGuide.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Профиль";
    var initials = "";
    if (!string.IsNullOrEmpty(Model.FullName))
    {
        var parts = Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        initials = parts.Length > 0 ? parts[0][0].ToString() : "";
        if (parts.Length > 1) initials += parts[1][0];
    }
    initials = initials.ToUpper();
}

<div class="container py-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Профиль -->
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <div class="avatar-circle mx-auto mb-4 position-relative" id="avatarContainer">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" alt="Avatar" class="avatar-img" id="avatarImage" />
                        }
                        else
                        {
                            <span class="avatar-initials" id="avatarInitials">@initials</span>
                        }
                        <label for="avatarInput" class="avatar-upload-btn" title="Изменить фото">
                            <small>Изменить</small>
                        </label>
                        <input type="file" id="avatarInput" accept="image/*" style="display:none" />
                    </div>
                    <div id="uploadProgress" class="mb-2" style="display:none;">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <small class="text-muted ms-1">Загрузка...</small>
                    </div>
                    <div id="uploadError" class="alert alert-danger py-1 px-2 mb-2" style="display:none;font-size:0.85rem;"></div>
                    
                    <h4 class="mb-1">@Model.FullName</h4>
                    <p class="text-muted mb-3">@Model.Email</p>
                    
                    <div class="mb-3">
                        @switch (Model.Role)
                        {
                            case "Admin":
                                <span class="badge bg-danger">Администратор</span>
                                break;
                            case "Manager":
                                <span class="badge bg-primary">Менеджер</span>
                                break;
                            default:
                                <span class="badge bg-success">Турист</span>
                                break;
                        }
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <p class="text-muted mb-1">@Model.Phone</p>
                    }
                    
                    <p class="text-muted small mb-0">На сайте с @Model.RegistrationDate.ToString("dd.MM.yyyy")</p>
                    
                    @if (!string.IsNullOrEmpty(Model.AgencyName))
                    {
                        <div class="mt-3 p-2 bg-light rounded">
                            <small class="text-muted">Агентство:</small>
                            <br><strong>@Model.AgencyName</strong>
                        </div>
                    }
                </div>
                <div class="card-footer bg-white border-top-0 pb-4">
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" class="btn btn-primary">Редактировать профиль</a>
                        <form asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger w-100">Выйти из аккаунта</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Статистика и действия -->
        <div class="col-lg-8">
            <div class="row g-4">
                <!-- Карточки статистики -->
                <div class="col-sm-4">
                    <a asp-controller="Favorites" asp-action="Index" class="text-decoration-none">
                        <div class="card shadow-sm h-100 hover-card">
                            <div class="card-body text-center py-4">
                                <h2 class="mb-1">@ViewBag.FavoritesCount</h2>
                                <small class="text-muted">Избранных туров</small>
                            </div>
                        </div>
                    </a>
                </div>
                
                <div class="col-sm-4">
                    <a asp-controller="Chat" asp-action="Index" class="text-decoration-none">
                        <div class="card shadow-sm h-100 hover-card">
                            <div class="card-body text-center py-4">
                                <h2 class="mb-1">@ViewBag.ChatsCount</h2>
                                <small class="text-muted">Чатов поддержки</small>
                            </div>
                        </div>
                    </a>
                </div>
                
                <div class="col-sm-4">
                    <a asp-controller="Tours" asp-action="Index" class="text-decoration-none">
                        <div class="card shadow-sm h-100 hover-card">
                            <div class="card-body text-center py-4">
                                <h5 class="mb-1">Каталог туров</h5>
                                <small class="text-muted">Искать туры</small>
                            </div>
                        </div>
                    </a>
                </div>
                
                <!-- Быстрые действия -->
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">Быстрые действия</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6 col-lg-3">
                                    <a asp-controller="Tours" asp-action="Index" class="btn btn-outline-primary w-100">
                                        Поиск туров
                                    </a>
                                </div>
                                <div class="col-md-6 col-lg-3">
                                    <a asp-controller="Hotels" asp-action="Index" class="btn btn-outline-success w-100">
                                        Отели
                                    </a>
                                </div>
                                <div class="col-md-6 col-lg-3">
                                    <a asp-controller="Sights" asp-action="Index" class="btn btn-outline-info w-100">
                                        Достопримечательности
                                    </a>
                                </div>
                                <div class="col-md-6 col-lg-3">
                                    <a asp-controller="Chat" asp-action="Create" class="btn btn-outline-warning w-100">
                                        Написать в чат
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Последние избранные туры -->
                @if (ViewBag.RecentFavorites != null && ((IEnumerable<TravelGuide.Models.Entities.FavoriteTour>)ViewBag.RecentFavorites).Any())
                {
                    <div class="col-12">
                        <div class="card shadow-sm">
                            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">Последние избранные</h5>
                                <a asp-controller="Favorites" asp-action="Index" class="btn btn-sm btn-outline-primary">Все</a>
                            </div>
                            <div class="card-body">
                                <div class="row g-3">
                                    @foreach (var fav in (IEnumerable<TravelGuide.Models.Entities.FavoriteTour>)ViewBag.RecentFavorites)
                                    {
                                        <div class="col-md-6 col-lg-4">
                                            <div class="card bg-light border-0 h-100">
                                                <div class="card-body">
                                                    <h6 class="mb-1">@fav.Tour?.Name</h6>
                                                    <small class="text-muted">@fav.Tour?.Country?.Name</small>
                                                    <div class="mt-2">
                                                        <strong class="text-primary">@fav.Tour?.Price.ToString("N0") ₽</strong>
                                                    </div>
                                                </div>
                                                <div class="card-footer bg-transparent border-0 pt-0">
                                                    <a asp-controller="Tours" asp-action="Details" asp-route-id="@fav.TourId" 
                                                       class="btn btn-sm btn-primary w-100">Подробнее</a>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('avatarInput').addEventListener('change', async function(e) {
            const file = e.target.files[0];
            if (!file) return;
            
            const progress = document.getElementById('uploadProgress');
            const errorDiv = document.getElementById('uploadError');
            const avatarImage = document.getElementById('avatarImage');
            const avatarInitials = document.getElementById('avatarInitials');
            
            errorDiv.style.display = 'none';
            progress.style.display = 'block';
            
            const formData = new FormData();
            formData.append('avatar', file);
            
            try {
                const response = await fetch('/Account/UploadAvatar', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    if (avatarInitials) avatarInitials.style.display = 'none';
                    if (avatarImage) {
                        avatarImage.src = result.avatarUrl + '?t=' + Date.now();
                        avatarImage.style.display = 'block';
                    } else {
                        const container = document.getElementById('avatarContainer');
                        const img = document.createElement('img');
                        img.src = result.avatarUrl + '?t=' + Date.now();
                        img.alt = 'Avatar';
                        img.className = 'avatar-img';
                        img.id = 'avatarImage';
                        container.insertBefore(img, container.firstChild);
                    }
                } else {
                    errorDiv.textContent = result.error;
                    errorDiv.style.display = 'block';
                }
            } catch (err) {
                errorDiv.textContent = 'Ошибка загрузки';
                errorDiv.style.display = 'block';
            } finally {
                progress.style.display = 'none';
                e.target.value = '';
            }
        });
    </script>
}