@model TravelGuide.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Профиль";
    var initials = "";
    if (!string.IsNullOrEmpty(Model.FullName))
    {
        var parts = Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        initials = parts.Length > 0 ? parts[0][0].ToString() : "";
        if (parts.Length > 1) initials += parts[1][0];
    }
    initials = initials.ToUpper();
}

<div class="container py-3">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Шапка профиля -->
    <div class="card tour-card mb-3">
        <div class="card-body p-3">
            <div class="d-flex align-items-center gap-4">
                <!-- Аватар -->
                <div class="position-relative flex-shrink-0" id="avatarContainer" style="width: 80px; height: 80px;">
                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="@Model.AvatarUrl" alt="Avatar" class="w-100 h-100 rounded-circle" style="object-fit: cover;" id="avatarImage" />
                    }
                    else
                    {
                        <div class="w-100 h-100 rounded-circle d-flex align-items-center justify-content-center" style="background: var(--primary); color: white; font-size: 1.5rem; font-weight: 600;" id="avatarInitials">
                            @initials
                        </div>
                    }
                    <label for="avatarInput" class="position-absolute bottom-0 end-0 rounded-circle d-flex align-items-center justify-content-center" 
                           style="width: 28px; height: 28px; background: var(--primary); color: white; cursor: pointer; font-size: 0.7rem; border: 2px solid white; box-shadow: 0 2px 6px rgba(0,0,0,0.15);"
                           title="Изменить фото">
                        Фото
                    </label>
                    <input type="file" id="avatarInput" accept="image/*" style="display:none" />
                </div>
                
                <!-- Информация -->
                <div class="flex-grow-1 min-width-0">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <h4 class="mb-0" style="font-weight: 600;">@Model.FullName</h4>
                        @switch (Model.Role)
                        {
                            case "Admin":
                                <span class="badge bg-danger">Администратор</span>
                                break;
                            case "Manager":
                                <span class="badge" style="background: var(--primary-light); color: var(--primary);">Менеджер</span>
                                break;
                            default:
                                <span class="badge" style="background: #d4edda; color: #155724;">Турист</span>
                                break;
                        }
                    </div>
                    <p class="text-muted mb-1 small">@Model.Email</p>
                    <div class="d-flex align-items-center gap-3 text-muted small">
                        @if (!string.IsNullOrEmpty(Model.Phone))
                        {
                            <span>@Model.Phone</span>
                        }
                        <span>На сайте с @Model.RegistrationDate.ToString("dd.MM.yyyy")</span>
                    </div>
                </div>
                
                <!-- Кнопки -->
                <div class="flex-shrink-0 d-flex gap-2">
                    <a asp-action="Edit" class="btn btn-primary btn-sm">Редактировать</a>
                    <form asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-secondary btn-sm">Выйти</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div id="uploadProgress" class="mb-2" style="display:none;">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <small class="text-muted ms-1">Загрузка...</small>
    </div>
    <div id="uploadError" class="alert alert-danger py-1 px-2 mb-2" style="display:none;font-size:0.85rem;"></div>

    <!-- Статистика -->
    <div class="row g-3 mb-3">
        <div class="col-sm-4">
            <a asp-controller="Favorites" asp-action="Index" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-3">
                        <div style="font-weight: 600; color: var(--primary); font-size: 1.5rem;">@ViewBag.FavoritesCount</div>
                        <div class="text-muted small">Избранных туров</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-4">
            <a asp-controller="Chat" asp-action="Index" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-3">
                        <div style="font-weight: 600; color: var(--primary); font-size: 1.5rem;">@ViewBag.ChatsCount</div>
                        <div class="text-muted small">Чатов поддержки</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-4">
            <a asp-controller="Bookings" asp-action="Index" class="text-decoration-none">
                <div class="card tour-card h-100">
                    <div class="card-body text-center py-3">
                        <div style="font-weight: 600; color: var(--primary); font-size: 1.5rem;">Брони</div>
                        <div class="text-muted small">Мои бронирования</div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Быстрые действия -->
    <div class="card tour-card mb-3">
        <div class="card-body p-3">
            <h5 class="mb-3" style="font-weight: 600;">Быстрые действия</h5>
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Tours" asp-action="Index" class="btn btn-outline-primary btn-sm">Поиск туров</a>
                <a asp-controller="Hotels" asp-action="Index" class="btn btn-outline-primary btn-sm">Отели</a>
                <a asp-controller="Sights" asp-action="Index" class="btn btn-outline-primary btn-sm">Достопримечательности</a>
                <a asp-controller="Chat" asp-action="Create" class="btn btn-outline-primary btn-sm">Написать в чат</a>
            </div>
        </div>
    </div>

    <!-- Последние избранные туры -->
    @if (ViewBag.RecentFavorites != null && ((IEnumerable<TravelGuide.Models.Entities.FavoriteTour>)ViewBag.RecentFavorites).Any())
    {
        <div class="card tour-card">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0" style="font-weight: 600;">Последние избранные</h5>
                    <a asp-controller="Favorites" asp-action="Index" class="btn btn-sm btn-outline-primary">Все</a>
                </div>
                <div class="row g-2">
                    @foreach (var fav in (IEnumerable<TravelGuide.Models.Entities.FavoriteTour>)ViewBag.RecentFavorites)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="d-flex align-items-center p-2 rounded-3" style="background: var(--bg-light);">
                                <div class="flex-grow-1 min-width-0">
                                    <a asp-controller="Tours" asp-action="Details" asp-route-id="@fav.TourId" class="text-decoration-none">
                                        <strong class="d-block text-truncate small" style="color: var(--text-dark);">@fav.Tour?.Name</strong>
                                    </a>
                                    <small class="text-muted">@fav.Tour?.Country?.Name</small>
                                    <div class="small" style="font-weight: 600; color: var(--primary);">@fav.Tour?.Price.ToString("N0") ₽</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.getElementById('avatarInput').addEventListener('change', async function(e) {
            const file = e.target.files[0];
            if (!file) return;
            
            const progress = document.getElementById('uploadProgress');
            const errorDiv = document.getElementById('uploadError');
            const avatarImage = document.getElementById('avatarImage');
            const avatarInitials = document.getElementById('avatarInitials');
            
            errorDiv.style.display = 'none';
            progress.style.display = 'block';
            
            const formData = new FormData();
            formData.append('avatar', file);
            
            try {
                const response = await fetch('/Account/UploadAvatar', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    if (avatarInitials) avatarInitials.style.display = 'none';
                    if (avatarImage) {
                        avatarImage.src = result.avatarUrl + '?t=' + Date.now();
                        avatarImage.style.display = 'block';
                    } else {
                        const container = document.getElementById('avatarContainer');
                        const img = document.createElement('img');
                        img.src = result.avatarUrl + '?t=' + Date.now();
                        img.alt = 'Avatar';
                        img.className = 'w-100 h-100 rounded-circle';
                        img.style.objectFit = 'cover';
                        img.id = 'avatarImage';
                        container.insertBefore(img, container.firstChild);
                    }
                } else {
                    errorDiv.textContent = result.error;
                    errorDiv.style.display = 'block';
                }
            } catch (err) {
                errorDiv.textContent = 'Ошибка загрузки';
                errorDiv.style.display = 'block';
            } finally {
                progress.style.display = 'none';
                e.target.value = '';
            }
        });
    </script>
}
