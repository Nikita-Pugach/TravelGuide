@model TravelGuide.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-icon">📝</div>
                <h3>Создайте аккаунт</h3>
                <p class="text-muted">Присоединяйтесь к TravelGuide</p>
            </div>
            
            <div class="auth-body">
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-sm"></div>
                    
                    <div class="form-group">
                        <label asp-for="FullName" class="form-label">ФИО</label>
                        <div class="input-group-custom">
                            <span class="input-icon">👤</span>
                            <input asp-for="FullName" class="form-control" placeholder="Иванов Иван Иванович" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-group">
                        <label asp-for="Email" class="form-label">Email</label>
                        <div class="input-group-custom">
                            <span class="input-icon">📧</span>
                            <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-group">
                        <label asp-for="Phone" class="form-label">Телефон</label>
                        <div class="input-group-custom">
                            <span class="input-icon">📱</span>
                            <input asp-for="Phone" class="form-control" placeholder="+7 (999) 123-45-67" />
                        </div>
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-group">
                        <label asp-for="Password" class="form-label">Пароль</label>
                        <div class="input-group-custom">
                            <span class="input-icon">🔒</span>
                            <input asp-for="Password" class="form-control" placeholder="Минимум 6 символов" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-group">
                        <label asp-for="ConfirmPassword" class="form-label">Подтвердите пароль</label>
                        <div class="input-group-custom">
                            <span class="input-icon">🔐</span>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Повторите пароль" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-auth btn-primary-gradient w-100">
                        Зарегистрироваться
                    </button>
                </form>
            </div>
            
            <div class="auth-footer">
                <p class="mb-2 text-muted">Уже есть аккаунт?</p>
                <a asp-action="Login" class="btn btn-outline-primary-gradient w-100">
                    Войти
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}