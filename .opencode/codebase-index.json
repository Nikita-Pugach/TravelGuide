{
  "embeddingProvider": "custom",
  "customProvider": {
    "baseUrl": "https://openrouter.ai/api/v1",
    "model": "openai/text-embedding-3-small",
    "dimensions": 1536,
    "apiKey": "{env:OPENROUTER_API_KEY}",
    "maxTokens": 8192,
    "timeoutMs": 30000,
    "maxBatchSize": 64
  },
  "scope": "project",
  "indexing": {
    "autoIndex": true,
    "watchFiles": true,
    "maxFileSize": 1048576,
    "maxChunksPerFile": 100,
    "semanticOnly": false,
    "autoGc": true
  },
  "search": {
    "maxResults": 20,
    "minScore": 0.1,
    "hybridWeight": 0.5,
    "fusionStrategy": "rrf",
    "rerankTopN": 50,
    "contextLines": 3
  }
}
